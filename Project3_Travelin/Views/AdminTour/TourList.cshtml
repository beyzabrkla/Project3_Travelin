@model List<ResultTourDTO>
@{
    ViewData["Title"] = "Tur Listesi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    string q = Context.Request.Query["q"];
    string country = Context.Request.Query["country"];
    string fromDate = Context.Request.Query["fromDate"];
    string toDate = Context.Request.Query["toDate"];
    int currentPage = ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages;
    // Filtre parametrelerini linklerde korumak için
    var queryParams = Context.Request.Query.ToDictionary(x => x.Key, x => x.Value.ToString());
}


<!-- PAGE HEADER -->
<div class="page-header">
    <div>
        <h1 class="page-title">Tur Listesi</h1>
        <nav aria-label="breadcrumb" class="mt-2">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="#">Admin</a></li>
                <li class="breadcrumb-item active" aria-current="page">Turlar</li>
            </ol>
        </nav>
    </div>
    <a href="/AdminTour/CreateTour" class="btn-brand">
        <i class="bi bi-plus-lg"></i> Yeni Tur Ekle
    </a>
</div>

<!-- FILTER CARD -->
<div class="filter-card">
    <form method="get" id="filterForm">
        <div class="row g-2 align-items-end">
            <div class="col-12 col-md-4">
                <label class="form-label fw-semibold" style="font-size:.78rem;color:#718096">Tur Ara</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0" style="border-radius:8px 0 0 8px;">
                        <i class="bi bi-search text-muted" style="font-size:.85rem;"></i>
                    </span>
                    <input type="text" name="q" value="@q" class="form-control border-start-0 ps-1" placeholder="Tur adı veya şehir..." style="border-radius:0 8px 8px 0;" />
                </div>
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label fw-semibold" style="font-size:.78rem;color:#718096">Ülke</label>
                <select name="country" class="form-select" style="border-radius:8px;font-size:.875rem;">
                    <option value="">Tümü</option>
                    @if (ViewBag.Countries != null)
                    {
                        foreach (var item in (List<string>)ViewBag.Countries)
                        {
                            <option value="@item" selected="@(Context.Request.Query["country"] == item)">
                                @item
                            </option>
                        }
                    }
                </select>
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label fw-semibold" style="font-size:.78rem;color:#718096">Başlangıç</label>
                <input type="date" name="fromDate" value="@fromDate" class="form-control" style="border-radius:8px;font-size:.875rem;" />
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label fw-semibold" style="font-size:.78rem;color:#718096">Bitiş</label>
                <input type="date" name="toDate" value="@toDate" class="form-control" style="border-radius:8px;font-size:.875rem;" />
            </div>
            <div class="col-6 col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-brand" style="border-radius:8px;font-size:.875rem;">
                    <i class="bi bi-funnel me-1"></i> Filtrele
                </button>
                <a href="?" class="btn btn-outline-secondary" style="border-radius:8px;font-size:.875rem;" aria-label="Filtreleri temizle">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </div>
    </form>
</div>

<!-- TABLE CARD -->
<div class="table-card">
    <div class="table-card-header">
        <div class="title" style="font-weight:700;">
            <i class="bi bi-table me-2"></i> Tüm Turlar
            <span class="tour-count-badge">@(Model?.Count ?? 0) tur</span>
        </div>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="empty-state">
            <i class="bi bi-map"></i>
            <p>Gösterilecek tur bulunamadı.</p>
            <a href="/AdminTour/CreateTour" class="btn btn-brand" style="border-radius:8px;">Yeni Tur Ekle</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="tours-table">
                <thead>
                    <tr>
                        <th>Görsel</th>
                        <th>Tur Başlığı</th>
                        <th>Ülke</th>
                        <th>Şehir</th>
                        <th>Tarih</th>
                        <th>Süre</th>
                        <th>Kapasite</th>
                        <th>Açıklama</th>
                        <th>Durum</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="td-image" data-label="">
                                @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="@item.TourTitle" class="tour-thumb" loading="lazy" />
                                }
                                else
                                {
                                    <div class="thumb-placeholder"><i class="bi bi-image"></i></div>
                                }
                            </td>
                            <td data-label="Başlık">
                                <span class="tour-title" title="@item.TourTitle">@item.TourTitle</span>
                            </td>
                            <td data-label="Ülke">
                                <span class="loc-badge"><i class="bi bi-globe2"></i>@item.TourCountry</span>
                            </td>
                            <td data-label="Şehir">
                                <span class="loc-badge"><i class="bi bi-geo-alt"></i>@item.TourCity</span>
                            </td>
                            <td data-label="Tarih">
                                <span class="date-cell"><i class="bi bi-calendar3 me-1 text-muted"></i>@item.TourDate.ToString("dd.MM.yyyy")</span>
                            </td>
                            <td data-label="Süre">
                                <span class="duration-pill"><i class="bi bi-clock me-1"></i>@item.DayNight</span>
                            </td>
                            <td data-label="Kapasite">
                                <span class="cap-cell"><i class="bi bi-people"></i>@item.TourCapacity</span>
                            </td>
                            <td data-label="Açıklama">
                                <span class="desc-cell">@((item.FullDescription?.Length > 80) ? item.FullDescription.Substring(0, 80) + "…" : item.FullDescription)</span>
                            </td>
                            <td data-label="Durum">
                                @if (item.IsDrafts)
                                {
                                    <span class="badge bg-warning text-dark"><i class="bi bi-pencil-fill me-1"></i>Taslak</span>
                                }
                                else if (item.IsStatus)
                                {
                                    <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Aktif</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary"><i class="bi bi-eye-slash me-1"></i>Pasif</span>
                                }
                            </td>
                            <td data-label="İşlemler">
                                <div class="action-group">
                                    <a asp-action="UpdateTour" asp-controller="AdminTour" asp-route-id="@item.TourId" class="btn-action btn-edit" title="Düzenle">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="CommentListByTourId" asp-controller="Comment" asp-route-id="@item.TourId" class="btn-action btn-detail" title="Detay">
                                        <i class="bi bi-chat-left-text"></i>
                                    </a>
                                    <button type="button" class="btn-action btn-delete" onclick="confirmDelete('@item.TourId', '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(item.TourTitle))')" title="Sil">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- PAGINATION -->
        <div class="pagination-wrapper">
            <span class="page-info">
                Toplam <strong>@ViewBag.TotalCount</strong> turdan
                <strong>@(((currentPage - 1) * ViewBag.PageSize) + 1) - @(Math.Min(currentPage * ViewBag.PageSize, ViewBag.TotalCount))</strong> arası gösteriliyor
            </span>

            <nav aria-label="Sayfalama">
                <ul class="pagination pagination-sm mb-0">
                    @* Önceki Sayfa *@
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        @{
                            queryParams["page"] = (currentPage - 1).ToString();
                        }
                        <a class="page-link" href="?@string.Join("&", queryParams.Select(p => $"{p.Key}={p.Value}"))"><i class="bi bi-chevron-left"></i></a>
                    </li>

                    @* Sayfa Numaraları *@
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        queryParams["page"] = i.ToString();
                        <li class="page-item @(currentPage == i ? "active" : "")">
                            <a class="page-link" href="?@string.Join("&", queryParams.Select(p => $"{p.Key}={p.Value}"))">@i</a>
                        </li>
                    }

                    @* Sonraki Sayfa *@
                    <li class="page-item @(currentPage == totalPages || totalPages == 0 ? "disabled" : "")">
                        @{
                            queryParams["page"] = (currentPage + 1).ToString();
                        }
                        <a class="page-link" href="?@string.Join("&", queryParams.Select(p => $"{p.Key}={p.Value}"))"><i class="bi bi-chevron-right"></i></a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

<!-- DELETE MODAL -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:420px">
        <div class="modal-content" style="border-radius:14px;border:0;box-shadow:0 20px 60px rgba(0,0,0,.15)">
            <div class="modal-body p-4 text-center">
                <div style="width:60px;height:60px;background:#fff5f5;border-radius:50%;display:grid;place-items:center;margin:0 auto 1.25rem;font-size:1.5rem;color:#e53e3e;">
                    <i class="bi bi-exclamation-triangle"></i>
                </div>
                <h5 style="font-family:var(--font-display);font-weight:700;font-size:1.1rem;color:#1a202c;margin-bottom:.5rem;">Tur Silinecek</h5>
                <p class="text-muted" style="font-size:.875rem;" id="deleteModalBody">Bu turu silmek istediğinize emin misiniz?</p>
            </div>
            <div class="modal-footer border-0 pt-0 pb-4 px-4 d-flex gap-2">
                <button type="button" class="btn btn-light flex-fill" data-bs-dismiss="modal" style="border-radius:9px;font-size:.875rem;">İptal</button>
                <form id="deleteForm" method="post" style="flex:1">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger w-100" style="border-radius:9px;font-size:.875rem;">
                        <i class="bi bi-trash3 me-1"></i> Evet, Sil
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(tourId, tourTitle) {
            document.getElementById('deleteModalBody').textContent =
                '"' + tourTitle + '" adlı tur kalıcı olarak silinecek. Bu işlem geri alınamaz.';
            document.getElementById('deleteForm').action = '/AdminTour/DeleteTour/' + tourId;
            new bootstrap.Modal(document.getElementById('deleteModal')).show();
        }
    </script>
}


