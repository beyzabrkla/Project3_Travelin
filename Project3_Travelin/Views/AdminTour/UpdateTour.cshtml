@model UpdateTourDTO
@{
    ViewData["Title"] = "Tur Düzenle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<!-- PAGE HEADER -->
<div class="page-header">
    <div>
        <h1 class="page-title">Tur Düzenle</h1>
        <nav aria-label="breadcrumb" class="mt-2">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="#">Admin</a></li>
                <li class="breadcrumb-item"><a asp-action="TourList">Turlar</a></li>
                <li class="breadcrumb-item active" aria-current="page">Tur Düzenle</li>
            </ol>
        </nav>
    </div>
    <a asp-action="TourList" class="btn btn-outline-secondary d-flex align-items-center gap-2"
       style="border-radius:10px;font-size:.875rem;font-weight:500;padding:.55rem 1.1rem;">
        <i class="bi bi-arrow-left"></i> Tur Listesine Dön
    </a>
</div>

<form asp-action="UpdateTour" method="post" id="updateTourForm" enctype="multipart/form-data">
   <input type="hidden" asp-for="TourId" />
    <input type="hidden" id="isStatusHidden" name="IsStatus" value="@Model.IsStatus.ToString().ToLower()" />
    <input type="hidden" id="isDraftsHidden" name="IsDrafts" value="@Model.IsDrafts.ToString().ToLower()" />
    @Html.AntiForgeryToken()

    <div class="form-grid">
        <div class="form-main">

            <!-- TEMEL BİLGİLER -->
            <div class="form-section">
                <div class="section-header">
                    <div class="section-icon blue"><i class="bi bi-info-circle"></i></div>
                    <div>
                        <div class="section-title">Temel Bilgiler</div>
                        <div class="section-subtitle">Turun başlığı ve açıklaması</div>
                    </div>
                </div>
                <div class="section-body">

                    <!-- Tur Başlığı -->
                    <div class="field-group">
                        <label asp-for="TourTitle" class="field-label">
                            <i class="bi bi-tag" style="color:#a0aec0;font-size:.85rem;"></i>
                            Tur Başlığı <span class="required">*</span>
                        </label>
                        <input asp-for="TourTitle" class="form-control"
                               placeholder="Örn: Kapadokya Balon Turu - 3 Gece 4 Gün"
                               maxlength="120" id="tourTitleInput" />
                        <div class="char-counter" id="titleCounter">0 / 120</div>
                        <span asp-validation-for="TourTitle" class="text-danger-field">
                            <i class="bi bi-exclamation-circle"></i><span></span>
                        </span>
                    </div>

                    <!-- Kısa Açıklama -->
                    <div class="field-group">
                        <label asp-for="SubDescription" class="field-label">
                            <i class="bi bi-card-text" style="color:#a0aec0;font-size:.85rem;"></i>
                            Kısa Açıklama <span class="required">*</span>
                        </label>
                        <input asp-for="SubDescription" class="form-control"
                               placeholder="Örn: Roma'nın tarihi güzelliklerini keşfedin..."
                               maxlength="200" id="subDescInput" />
                        <div class="char-counter" id="subDescCounter">0 / 200</div>
                        <span asp-validation-for="SubDescription" class="text-danger-field">
                            <i class="bi bi-exclamation-circle"></i><span></span>
                        </span>
                    </div>

                    <!-- Detaylı Açıklama -->
                    <div class="field-group">
                        <label asp-for="FullDescription" class="field-label">
                            <i class="bi bi-text-left" style="color:#a0aec0;font-size:.85rem;"></i>
                            Detaylı Açıklama <span class="required">*</span>
                        </label>
                        <textarea asp-for="FullDescription" class="form-control"
                                  placeholder="Tur hakkında detaylı açıklama yazın..."
                                  maxlength="1000" id="descInput" rows="5"></textarea>
                        <div class="char-counter" id="descCounter">0 / 1000</div>
                        <span asp-validation-for="FullDescription" class="text-danger-field">
                            <i class="bi bi-exclamation-circle"></i><span></span>
                        </span>
                    </div>

                </div>
            </div>

            <!-- KONUM BİLGİLERİ -->
            <div class="form-section">
                <div class="section-header">
                    <div class="section-icon green"><i class="bi bi-geo-alt"></i></div>
                    <div>
                        <div class="section-title">Konum Bilgileri</div>
                        <div class="section-subtitle">Turun gideceği ülke ve şehir</div>
                    </div>
                </div>
                <div class="section-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="field-group">
                                <label asp-for="TourCountry" class="field-label">
                                    <i class="bi bi-globe2" style="color:#a0aec0;font-size:.85rem;"></i>
                                    Ülke <span class="required">*</span>
                                </label>
                                <select asp-for="TourCountry" class="form-select" id="countrySelect">
                                    <option value="">Seçiniz...</option>
                                    @if (ViewBag.Countries != null)
                                    {
                                        foreach (var item in (List<string>)ViewBag.Countries)
                                        {
                                            <option value="@item" selected="@(item == Model.TourCountry ? "selected" : null)">@item</option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="TourCountry" class="text-danger-field">
                                    <i class="bi bi-exclamation-circle"></i><span></span>
                                </span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="field-group">
                                <label asp-for="TourCity" class="field-label">
                                    <i class="bi bi-building" style="color:#a0aec0;font-size:.85rem;"></i>
                                    Şehir <span class="required">*</span>
                                </label>
                                <div class="input-with-icon">
                                    <i class="bi bi-geo-alt input-icon"></i>
                                    <input asp-for="TourCity" class="form-control"
                                           placeholder="Örn: Nevşehir, Kapadokya" id="cityInput" />
                                </div>
                                <span asp-validation-for="TourCity" class="text-danger-field">
                                    <i class="bi bi-exclamation-circle"></i><span></span>
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- TUR DETAYLARI -->
            <div class="form-section">
                <div class="section-header">
                    <div class="section-icon amber"><i class="bi bi-calendar3"></i></div>
                    <div>
                        <div class="section-title">Tur Detayları</div>
                        <div class="section-subtitle">Tarih, süre ve kapasite bilgileri</div>
                    </div>
                </div>
                <div class="section-body">
                    <div class="row g-3">

                        <!-- Tur Tarihi -->
                        <div class="col-md-6">
                            <div class="field-group">
                                <label asp-for="TourDate" class="field-label">
                                    <i class="bi bi-calendar-event" style="color:#a0aec0;font-size:.85rem;"></i>
                                    Tur Tarihi <span class="required">*</span>
                                </label>
                                <div class="input-with-icon">
                                    <i class="bi bi-calendar3 input-icon"></i>
                                    <input asp-for="TourDate" type="date" class="form-control"
                                           id="tourDateInput" min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                                </div>
                                <div class="field-hint">
                                    <i class="bi bi-info-circle me-1"></i>Bugünden önceki tarih seçilemez.
                                </div>
                                <span asp-validation-for="TourDate" class="text-danger-field">
                                    <i class="bi bi-exclamation-circle"></i><span></span>
                                </span>
                            </div>
                        </div>

                        <!-- Kapasite -->
                        <div class="col-md-6">
                            <div class="field-group">
                                <label asp-for="TourCapacity" class="field-label">
                                    <i class="bi bi-people" style="color:#a0aec0;font-size:.85rem;"></i>
                                    Kapasite <span class="required">*</span>
                                </label>
                                <div class="stepper">
                                    <button type="button" class="stepper-btn" onclick="stepperDecrement()" aria-label="Azalt">
                                        <i class="bi bi-dash"></i>
                                    </button>
                                    <input asp-for="TourCapacity" type="number" min="1" max="500" id="capacityInput" />
                                    <button type="button" class="stepper-btn" onclick="stepperIncrement()" aria-label="Artır">
                                        <i class="bi bi-plus"></i>
                                    </button>
                                </div>
                                <div class="field-hint">
                                    <i class="bi bi-info-circle me-1"></i>Maksimum katılımcı sayısı (1–500)
                                </div>
                                <span asp-validation-for="TourCapacity" class="text-danger-field">
                                    <i class="bi bi-exclamation-circle"></i><span></span>
                                </span>
                            </div>
                        </div>

                        <!-- Tur Fiyatı -->
                        <div class="col-md-6">
                            <div class="field-group">
                                <label asp-for="TourPrice" class="field-label">
                                    <i class="bi bi-currency-dollar" style="color:#a0aec0;font-size:.85rem;"></i>
                                    Tur Fiyatı <span class="required">*</span>
                                </label>
                                <div class="input-with-icon">
                                    <i class="bi bi-cash-stack input-icon"></i>
                                    <input asp-for="TourPrice" type="number" step="0.01" class="form-control" placeholder="0.00" />
                                </div>
                            </div>
                        </div>

                        <!-- Rehber -->
                        <div class="col-md-6">
                            <div class="field-group">
                                <label asp-for="GuideId" class="field-label">
                                    <i class="bi bi-person-badge" style="color:#a0aec0;font-size:.85rem;"></i>
                                    Tur Rehberi
                                </label>
                                <select asp-for="GuideId" class="form-select"
                                        asp-items="@(ViewBag.Guides as List<SelectListItem>)">
                                    <option value="">Rehber Seçiniz...</option>
                                </select>
                            </div>
                        </div>

                        <!-- Tur Süresi -->
                        <div class="col-12">
                            <div class="field-group">
                                <label class="field-label">
                                    <i class="bi bi-clock" style="color:#a0aec0;font-size:.85rem;"></i>
                                    Tur Süresi <span class="required">*</span>
                                </label>
                                <div class="duration-builder">
                                    <div class="duration-unit">
                                        <label for="dayCount">Gün Sayısı</label>
                                        <div class="input-with-icon">
                                            <i class="bi bi-sun input-icon"></i>
                                            <input type="number" id="dayCount" min="1" max="30" class="form-control" placeholder="3" />
                                        </div>
                                    </div>
                                    <div class="duration-unit">
                                        <label for="nightCount">Gece Sayısı</label>
                                        <div class="input-with-icon">
                                            <i class="bi bi-moon input-icon"></i>
                                            <input type="number" id="nightCount" min="0" max="30" class="form-control" placeholder="2" />
                                        </div>
                                    </div>
                                </div>
                                <input asp-for="DayNight" type="hidden" id="dayNightHidden" />
                                <div class="field-hint" id="durationPreview">
                                    <i class="bi bi-clock me-1"></i>Önizleme: <strong id="durationText">—</strong>
                                </div>
                                <span asp-validation-for="DayNight" class="text-danger-field">
                                    <i class="bi bi-exclamation-circle"></i><span></span>
                                </span>
                            </div>
                        </div>

                    </div>
                </div>
            </div>


            <!-- ✅ VİZE & VİDEO BİLGİLERİ -->
            <div class="form-section">
                <div class="section-header">
                    <div class="section-icon amber"><i class="bi bi-passport"></i></div>
                    <div>
                        <div class="section-title">Vize & Video</div>
                        <div class="section-subtitle">Vize durumu ve tanıtım videosu</div>
                    </div>
                </div>
                <div class="section-body">
                    <div class="row g-3">

                        <!-- Vize Durumu -->
                        <div class="col-12">
                            <div class="field-group">
                                <label class="field-label">
                                    <i class="bi bi-passport" style="color:#a0aec0;font-size:.85rem;"></i>
                                    Vize Durumu <span class="required">*</span>
                                </label>
                                <div class="d-flex gap-3 mt-1">
                                    <label class="visa-option" id="visaRequired">
                                        <input type="radio" name="VisaRadio" value="true" onchange="updateVisa(this)" />
                                        <span class="visa-dot" style="background:#e53e3e;"></span>
                                        <div class="status-text">
                                            <div class="stitle">Vize Gerekiyor</div>
                                            <div class="ssub">Pasaport + vize şartı var</div>
                                        </div>
                                        <i class="bi bi-x-circle-fill ms-auto" style="color:#e53e3e;font-size:.95rem;"></i>
                                    </label>
                                    <label class="visa-option" id="visaNotRequired">
                                        <input type="radio" name="VisaRadio" value="false" onchange="updateVisa(this)" />
                                        <span class="visa-dot" style="background:#16a34a;"></span>
                                        <div class="status-text">
                                            <div class="stitle">Vizesiz</div>
                                            <div class="ssub">Vize gerekmez</div>
                                        </div>
                                        <i class="bi bi-check-circle-fill ms-auto" style="color:#16a34a;font-size:.95rem;"></i>
                                    </label>
                                </div>
                                <input type="hidden" id="isVisaRequiredHidden" name="IsVisaRequired" value="@Model.IsVisaRequired.ToString().ToLower()" />
                                <div class="field-hint mt-2">
                                    <i class="bi bi-info-circle me-1"></i>Bu seçim tur listesinde filtre olarak görünür.
                                </div>
                            </div>
                        </div>

                        <!-- Video URL -->
                        <div class="col-12">
                            <div class="field-group">
                                <label class="field-label">
                                    <i class="bi bi-play-circle" style="color:#a0aec0;font-size:.85rem;"></i>
                                    Tanıtım Video URL <span style="color:#a0aec0;font-size:.78rem;">(isteğe bağlı)</span>
                                </label>
                                <div class="input-with-icon">
                                    <i class="bi bi-youtube input-icon" style="color:#ff0000;"></i>
                                    <input asp-for="VideoUrl" type="url" class="form-control"
                                           placeholder="https://www.youtube.com/watch?v=..."
                                           id="videoUrlInput" />
                                </div>
                                <div class="field-hint">
                                    <i class="bi bi-info-circle me-1"></i>YouTube veya Vimeo linki girin.
                                </div>
                                <!-- Video önizleme -->
                                <div id="videoPreview" class="mt-2" style="display:none;">
                                    <iframe id="videoIframe" width="100%" height="220"
                                            style="border-radius:8px;border:1px solid #e2e8f0;"
                                            allowfullscreen></iframe>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <!-- ✅ DÜZELTİLDİ: HARİTA GÖRSELİ — Artık kendi form-section'ı içinde -->
            <div class="form-section">
                <div class="section-header">
                    <div class="section-icon green"><i class="bi bi-map"></i></div>
                    <div>
                        <div class="section-title">Harita Görseli</div>
                        <div class="section-subtitle">Tur güzergah haritası</div>
                    </div>
                </div>
                <div class="section-body">
                    <div class="field-group">
                        <!-- Mevcut harita görseli varsa göster -->
                        @if (!string.IsNullOrEmpty(Model.MapImageUrl))
                        {
                            <div class="mb-3">
                                <p class="field-hint"><i class="bi bi-info-circle me-1"></i>Mevcut harita görseli:</p>
                                <img src="/userimages/@Model.MapImageUrl" alt="Mevcut harita"
                                     style="max-width:200px;border-radius:8px;border:1px solid #e2e8f0;" />
                            </div>
                        }

                        <div class="image-upload-zone" id="mapUploadZone">
                            @* ✅ DÜZELTİLDİ: name="MapImageFile" zaten var, form içinde ve doğru konumda *@
                            <input type="file" name="MapImageFile" id="mapFileInput" accept="image/*" />
                            <div class="upload-icon"><i class="bi bi-map"></i></div>
                            <div class="upload-title">Harita Dosyası Yükle</div>
                            <div class="upload-sub">PNG, JPG, WebP — Maks. 5MB</div>
                        </div>

                        <div class="image-preview-box mt-3" id="mapPreviewBox" style="display:none;">
                            <img src="" alt="Harita önizleme" id="mapPreviewImg" />
                            <div class="preview-overlay">
                                <button type="button" class="preview-remove" onclick="removeMapImage()">
                                    <i class="bi bi-trash3"></i> Haritayı Kaldır
                                </button>
                            </div>
                        </div>

                        <input type="hidden" asp-for="MapImageUrl" id="mapImageUrlHidden" />
                    </div>
                </div>
            </div>

            <!-- GÖRSEL -->
            <div class="form-section">
                <div class="section-header">
                    <div class="section-icon purple"><i class="bi bi-image"></i></div>
                    <div>
                        <div class="section-title">Tur Görseli</div>
                        <div class="section-subtitle">URL girin veya dosya yükleyin</div>
                    </div>
                </div>
                <div class="section-body">
                    <div class="field-group">
                        <label asp-for="ImageUrl" class="field-label">
                            <i class="bi bi-link-45deg" style="color:#a0aec0;font-size:.85rem;"></i>
                            Görsel URL
                        </label>
                        <div class="input-with-icon">
                            <i class="bi bi-link-45deg input-icon"></i>
                            <input asp-for="ImageUrl" type="url" class="form-control"
                                   placeholder="https://ornek.com/gorsel.jpg" id="imageUrlInput" />
                        </div>
                        <div class="field-hint"><i class="bi bi-info-circle me-1"></i>JPEG, PNG, WebP desteklenir.</div>
                        <img src="" alt="Görsel önizleme" class="url-preview-thumb" id="urlPreviewImg" style="display:none;" />
                        <span asp-validation-for="ImageUrl" class="text-danger-field">
                            <i class="bi bi-exclamation-circle"></i><span></span>
                        </span>
                    </div>

                    <div class="d-flex align-items-center gap-3 my-3">
                        <div style="flex:1;height:1px;background:#e2e8f0;"></div>
                        <span style="font-size:.73rem;color:#a0aec0;font-weight:600;text-transform:uppercase;letter-spacing:.06em;">veya</span>
                        <div style="flex:1;height:1px;background:#e2e8f0;"></div>
                    </div>

                    <div class="image-upload-zone" id="uploadZone">
                        @* ✅ DÜZELTİLDİ: name="ImageFile" EKLENDİ — önceden yoktu, dosya hiç gelmiyordu *@
                        <input type="file" name="ImageFile" accept="image/*" id="imageFileInput" aria-label="Görsel dosyası seç" />
                        <div class="upload-icon"><i class="bi bi-cloud-arrow-up"></i></div>
                        <div class="upload-title">Dosya sürükleyin veya seçin</div>
                        <div class="upload-sub">PNG, JPG, WebP — Maks. 5MB</div>
                    </div>

                    <div class="image-preview-box mt-3" id="previewBox" style="display:none;">
                        <img src="" alt="Yüklenen görsel önizleme" id="previewImg" />
                        <div class="preview-overlay">
                            <button type="button" class="preview-remove" onclick="removeImage()">
                                <i class="bi bi-trash3"></i> Görseli Kaldır
                            </button>
                        </div>
                    </div>
                </div>
            </div>

        </div><!-- /form-main -->
        <!-- SIDEBAR PANEL -->
        <div class="sidebar-panel">

            <!-- YAYIM DURUMU -->
            <div class="form-section">
                <div class="section-header">
                    <div class="section-icon green"><i class="bi bi-send-check"></i></div>
                    <div>
                        <div class="section-title">Yayım Durumu</div>
                        <div class="section-subtitle">Tur hangi durumda yayımlansın?</div>
                    </div>
                </div>
                <div class="section-body">
                    <label class="status-option" id="statusActive">
                        <input type="radio" name="PublishStatus" value="active" onchange="updateStatus(this)" />
                        <span class="status-dot dot-active"></span>
                        <div class="status-text">
                            <div class="stitle">Aktif</div>
                            <div class="ssub">Hemen yayımla</div>
                        </div>
                        <i class="bi bi-check-circle-fill ms-auto" style="color:#16a34a;font-size:.95rem;"></i>
                    </label>
                    <label class="status-option" id="statusDraft">
                        <input type="radio" name="PublishStatus" value="draft" onchange="updateStatus(this)" />
                        <span class="status-dot dot-draft"></span>
                        <div class="status-text">
                            <div class="stitle">Taslak</div>
                            <div class="ssub">Şimdilik gizle</div>
                        </div>
                    </label>
                    <label class="status-option" id="statusPassive">
                        <input type="radio" name="PublishStatus" value="passive" onchange="updateStatus(this)" />
                        <span class="status-dot dot-passive"></span>
                        <div class="status-text">
                            <div class="stitle">Pasif</div>
                            <div class="ssub">Yayımdan kaldır</div>
                        </div>
                    </label>
                </div>
            </div>

            <!-- TUR ÖZETİ -->
            <div class="form-section">
                <div class="section-header">
                    <div class="section-icon blue"><i class="bi bi-eye"></i></div>
                    <div>
                        <div class="section-title">Tur Özeti</div>
                        <div class="section-subtitle">Canlı önizleme</div>
                    </div>
                </div>
                <div class="section-body">
                    <div class="summary-box">
                        <div class="summary-row">
                            <span class="label">Başlık</span>
                            <span class="value" id="sumTitle"
                                  style="max-width:150px;text-align:right;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">—</span>
                        </div>
                        <div class="summary-row">
                            <span class="label">Ülke / Şehir</span>
                            <span class="value" id="sumLocation">—</span>
                        </div>
                        <div class="summary-row">
                            <span class="label">Tarih</span>
                            <span class="value" id="sumDate">—</span>
                        </div>
                        <div class="summary-row">
                            <span class="label">Süre</span>
                            <span class="value" id="sumDuration">—</span>
                        </div>
                        <div class="summary-row">
                            <span class="label">Kapasite</span>
                            <span class="value" id="sumCapacity">—</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- BUTONLAR -->
            <div class="form-section">
                <div class="section-body">
                    <div class="form-actions">
                        <button type="submit" class="btn btn-brand" id="submitBtn">
                            <i class="bi bi-plus-circle-fill"></i>
                            Turu Kaydet
                        </button>
                        <button type="button" class="btn-draft" onclick="saveDraft()">
                            <i class="bi bi-floppy"></i>
                            Taslak Olarak Kaydet
                        </button>
                        <a asp-action="TourList" class="btn-cancel">
                            <i class="bi bi-x me-1"></i>İptal et, geri dön
                        </a>
                    </div>
                </div>
            </div>

            <!-- İPUÇLARI -->
            <div class="form-section">
                <div class="section-header" style="background:none;">
                    <div class="section-icon amber"><i class="bi bi-lightbulb"></i></div>
                    <div>
                        <div class="section-title">İpuçları</div>
                    </div>
                </div>
                <div class="section-body" style="padding-top:.75rem;">
                    <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:.6rem;">
                        <li style="font-size:.78rem;color:#718096;display:flex;gap:.5rem;align-items:flex-start;">
                            <i class="bi bi-check2-circle" style="color:#16a34a;margin-top:1px;flex-shrink:0;"></i>
                            Başlık <strong>60–80 karakter</strong> arasında olmalı.
                        </li>
                        <li style="font-size:.78rem;color:#718096;display:flex;gap:.5rem;align-items:flex-start;">
                            <i class="bi bi-check2-circle" style="color:#16a34a;margin-top:1px;flex-shrink:0;"></i>
                            Kısa açıklama tur listesinde görünen özet metindir.
                        </li>
                        <li style="font-size:.78rem;color:#718096;display:flex;gap:.5rem;align-items:flex-start;">
                            <i class="bi bi-check2-circle" style="color:#16a34a;margin-top:1px;flex-shrink:0;"></i>
                            Görselin en az <strong>1200×800px</strong> çözünürlükte olması önerilir.
                        </li>
                        <li style="font-size:.78rem;color:#718096;display:flex;gap:.5rem;align-items:flex-start;">
                            <i class="bi bi-check2-circle" style="color:#16a34a;margin-top:1px;flex-shrink:0;"></i>
                            Kapasite doluluk oranı rezervasyon panelinden takip edilir.
                        </li>
                    </ul>
                </div>
            </div>

        </div><!-- /sidebar-panel -->

    </div><!-- /form-grid -->
</form>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.13/jquery.validate.unobtrusive.min.js"></script>

<style>
    /* Vize seçenek kartları */
    .visa-option {
        display: flex;
        align-items: center;
        gap: .75rem;
        padding: .75rem 1rem;
        border: 1.5px solid #e2e8f0;
        border-radius: 10px;
        cursor: pointer;
        transition: all .2s;
        flex: 1;
        background: #fff;
    }

        .visa-option input[type="radio"] {
            display: none;
        }

    .visa-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .visa-option.selected-active {
        border-color: #16a34a;
        background: #f0fdf4;
    }

    .visa-option.selected-passive {
        border-color: #e53e3e;
        background: #fff5f5;
    }

    .visa-option:hover {
        border-color: #a0aec0;
    }

</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>

        // ── MAP FILE UPLOAD PREVIEW ────────────────────────────────────
        const mapUploadZone = document.getElementById('mapUploadZone');
        const mapFileInput  = document.getElementById('mapFileInput');
        const mapPreviewBox = document.getElementById('mapPreviewBox');
        const mapPreviewImg = document.getElementById('mapPreviewImg');

        if (mapFileInput) {
            mapFileInput.addEventListener('change', function () {
                const file = this.files[0];
                if (!file) return;
                const reader = new FileReader();
                reader.onload = function (e) {
                    mapPreviewImg.src = e.target.result;
                    mapPreviewBox.style.display = 'block';
                    mapUploadZone.style.display  = 'none';
                };
                reader.readAsDataURL(file);
            });
        }

        function removeMapImage() {
            mapPreviewBox.style.display = 'none';
            mapUploadZone.style.display  = 'block';
            mapFileInput.value = '';
            mapPreviewImg.src  = '';
            document.getElementById('mapImageUrlHidden').value = '';
        }

        // ── CHAR COUNTERS ─────────────────────────────────────────────
        function initCounter(inputId, counterId, max) {
            const el      = document.getElementById(inputId);
            const counter = document.getElementById(counterId);
            if (!el || !counter) return;
            function update() {
                const len = el.value.length;
                counter.textContent = len + ' / ' + max;
                counter.className   = 'char-counter' + (len > max * .9 ? (len >= max ? ' danger' : ' warn') : '');
            }
            el.addEventListener('input', update);
            update();
        }
        initCounter('tourTitleInput', 'titleCounter',   120);
        initCounter('subDescInput',   'subDescCounter', 200);
        initCounter('descInput',      'descCounter',   1000);

        // ── STEPPER ───────────────────────────────────────────────────
        function stepperDecrement() {
            const inp = document.getElementById('capacityInput');
            const val = parseInt(inp.value) || 1;
            if (val > 1) { inp.value = val - 1; updateSummary(); }
        }
        function stepperIncrement() {
            const inp = document.getElementById('capacityInput');
            const val = parseInt(inp.value) || 1;
            if (val < 500) { inp.value = val + 1; updateSummary(); }
        }
        document.getElementById('capacityInput').addEventListener('input', updateSummary);

        // ── DURATION BUILDER ──────────────────────────────────────────
        function updateDuration() {
            const days   = parseInt(document.getElementById('dayCount').value)   || 0;
            const nights = parseInt(document.getElementById('nightCount').value) || 0;
            const text   = days + ' Gün / ' + nights + ' Gece';
            document.getElementById('dayNightHidden').value     = text;
            document.getElementById('durationText').textContent = text;
            updateSummary();
        }
        document.getElementById('dayCount').addEventListener('input', updateDuration);
        document.getElementById('nightCount').addEventListener('input', updateDuration);

        (function initDuration() {
            const existing = document.getElementById('dayNightHidden').value || '';
            const match    = existing.match(/(\d+)\s*Gün\s*\/\s*(\d+)\s*Gece/i);
            if (match) {
                document.getElementById('dayCount').value    = match[1];
                document.getElementById('nightCount').value = match[2];
                document.getElementById('durationText').textContent = match[1] + ' Gün / ' + match[2] + ' Gece';
            } else {
                document.getElementById('dayCount').value    = 1;
                document.getElementById('nightCount').value = 0;
                updateDuration();
            }
            updateSummary();
        })();

        // ── IMAGE URL PREVIEW ─────────────────────────────────────────
        const imageUrlInput = document.getElementById('imageUrlInput');
        const urlPreviewImg = document.getElementById('urlPreviewImg');
        let urlDebounce;

        imageUrlInput.addEventListener('input', function () {
            clearTimeout(urlDebounce);
            urlDebounce = setTimeout(function () {
                const url = imageUrlInput.value.trim();
                if (url) {
                    urlPreviewImg.src = url;
                    urlPreviewImg.style.display = 'block';
                    urlPreviewImg.onerror = function () { urlPreviewImg.style.display = 'none'; };
                } else {
                    urlPreviewImg.style.display = 'none';
                }
            }, 600);
        });

        (function initImagePreview() {
            const existingUrl = imageUrlInput.value.trim();
            if (existingUrl) {
                urlPreviewImg.src = existingUrl;
                urlPreviewImg.style.display = 'block';
            }
        })();

        // ── FILE UPLOAD PREVIEW ───────────────────────────────────────
        const uploadZone     = document.getElementById('uploadZone');
        const imageFileInput = document.getElementById('imageFileInput');
        const previewBox     = document.getElementById('previewBox');
        const previewImg     = document.getElementById('previewImg');

        imageFileInput.addEventListener('change', function () {
            const file = this.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = function (e) {
                previewImg.src = e.target.result;
                previewBox.style.display = 'block';
                uploadZone.style.display = 'none';
            };
            reader.readAsDataURL(file);
        });

        ['dragover', 'dragleave', 'drop'].forEach(function (evt) {
            uploadZone.addEventListener(evt, function (e) {
                e.preventDefault();
                if (evt === 'dragover') uploadZone.classList.add('dragover');
                else uploadZone.classList.remove('dragover');
                if (evt === 'drop' && e.dataTransfer.files[0]) {
                    imageFileInput.files = e.dataTransfer.files;
                    imageFileInput.dispatchEvent(new Event('change'));
                }
            });
        });

        function removeImage() {
            previewBox.style.display  = 'none';
            uploadZone.style.display  = 'block';
            imageFileInput.value = '';
            previewImg.src = '';
        }

        // ── YAYIM DURUMU ──────────────────────────────────────────────
        function updateStatus(radio) {
            $('.status-option').removeClass('selected-active selected-draft selected-passive');
            const val    = radio.value;
            const parent = $(radio).closest('.status-option');
            if (val === 'active') {
                parent.addClass('selected-active');
                $('#isStatusHidden').val("true");
                $('#isDraftsHidden').val("false");
            } else if (val === 'draft') {
                parent.addClass('selected-draft');
                $('#isStatusHidden').val("false");
                $('#isDraftsHidden').val("true");
            } else if (val === 'passive') {
                parent.addClass('selected-passive');
                $('#isStatusHidden').val("false");
                $('#isDraftsHidden').val("false");
            }
        }

        window.addEventListener('DOMContentLoaded', function () {
            const isStatus = "@Model.IsStatus".toLowerCase() === "true";
            const isDraft  = "@Model.IsDrafts".toLowerCase() === "true";
            let targetValue = "passive";
            if (isDraft)       targetValue = "draft";
            else if (isStatus) targetValue = "active";
            const targetRadio = document.querySelector('input[name="PublishStatus"][value="' + targetValue + '"]');
            if (targetRadio) { targetRadio.checked = true; updateStatus(targetRadio); }
        });

        // ── LIVE SUMMARY ──────────────────────────────────────────────
        function updateSummary() {
            const title    = document.getElementById('tourTitleInput').value.trim();
            const country  = document.getElementById('countrySelect').value;
            const city     = document.getElementById('cityInput')?.value.trim();
            const date     = document.getElementById('tourDateInput').value;
            const duration = document.getElementById('dayNightHidden').value;
            const capacity = document.getElementById('capacityInput').value;

            document.getElementById('sumTitle').textContent    = title    || '—';
            document.getElementById('sumLocation').textContent = (country && city) ? country + ' / ' + city : (country || city || '—');
            document.getElementById('sumDate').textContent     = date     ? formatDate(date) : '—';
            document.getElementById('sumDuration').textContent = duration || '—';
            document.getElementById('sumCapacity').textContent = capacity ? capacity + ' kişi' : '—';
        }

        function formatDate(dateStr) {
            const [y, m, d] = dateStr.split('-');
            return d + '.' + m + '.' + y;
        }

        ['tourTitleInput', 'countrySelect', 'cityInput', 'tourDateInput', 'capacityInput'].forEach(function (id) {
            const el = document.getElementById(id);
            if (el) el.addEventListener('input', updateSummary);
        });
        updateSummary();

        // ── DRAFT SAVE ────────────────────────────────────────────────
        function saveDraft() {
            $('#isStatusHidden').val("false");
            $('#isDraftsHidden').val("true");
            document.getElementById('updateTourForm').submit();
        }

        // ── FORM SUBMIT ───────────────────────────────────────────────
        $(document).ready(function () {
            $('#updateTourForm').on('submit', function (e) {
                if (!$(this).valid()) {
                    console.warn("Hatalı alanlar:", $(this).validate().errorList);
                    return false;
                }
                const btn = $('#submitBtn');
                btn.prop('disabled', true);
                btn.html('<span class="spinner-border spinner-border-sm me-2"></span>İşlem yapılıyor...');
                return true;
            });
        });


        // ── VİZE DURUMU ───────────────────────────────────────────────
        function updateVisa(radio) {
            document.querySelectorAll('.visa-option').forEach(el => el.classList.remove('selected-active', 'selected-passive'));
            const parent = radio.closest('.visa-option');
            document.getElementById('isVisaRequiredHidden').value = radio.value;
            if (radio.value === 'true') parent.classList.add('selected-passive');
            else parent.classList.add('selected-active');
        }

        (function initVisa() {
            const existing = document.getElementById('isVisaRequiredHidden').value;
            const targetVal = (existing === 'true' || existing === 'True') ? 'true' : 'false';
            const targetRadio = document.querySelector('input[name="VisaRadio"][value="' + targetVal + '"]');
            if (targetRadio) { targetRadio.checked = true; updateVisa(targetRadio); }
        })();

        // ── VİDEO ÖNİZLEME ───────────────────────────────────────────
        const videoUrlInput = document.getElementById('videoUrlInput');
        if (videoUrlInput) {
            videoUrlInput.addEventListener('input', function () {
                const url = this.value.trim();
                const preview = document.getElementById('videoPreview');
                const iframe  = document.getElementById('videoIframe');
                if (!url) { preview.style.display = 'none'; return; }
                const ytMatch = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([^&\s]+)/);
                if (ytMatch) {
                    iframe.src = 'https://www.youtube.com/embed/' + ytMatch[1];
                    preview.style.display = 'block';
                    return;
                }
                const vimeoMatch = url.match(/vimeo\.com\/(\d+)/);
                if (vimeoMatch) {
                    iframe.src = 'https://player.vimeo.com/video/' + vimeoMatch[1];
                    preview.style.display = 'block';
                    return;
                }
                preview.style.display = 'none';
            });

            // Init video preview if existing URL
            if (videoUrlInput.value.trim()) {
                videoUrlInput.dispatchEvent(new Event('input'));
            }
        }

    </script>
}
