@model List<ResultReservationDTO>
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_CustomerLayout.cshtml";
}
@if (ViewBag.PendingCount > 0)
{
    <div class="alert alert-warning border-0 shadow-sm d-flex align-items-center" style="border-radius: 12px; background-color: #fffbeb;">
        <i class="bi bi-exclamation-triangle-fill me-3" style="font-size: 1.5rem; color: #f59e0b;"></i>
        <div>
            <h6 class="mb-0 fw-bold" style="color: #92400e;">İşlem Bekleyen Rezervasyonunuz Var</h6>
            <small style="color: #b45309;">Şu anda @ViewBag.PendingCount adet rezervasyonunuz admin onayı beklemektedir.</small>
        </div>
    </div>
}
<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="page-title" style="color: #2d3748; font-weight: 700;">Hoş Geldin, @User.Identity.Name!</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/Default/Index">Ana Sayfa</a></li>
                <li class="breadcrumb-item active" aria-current="page">Müşteri Paneli</li>
            </ol>
        </nav>
    </div>
    <a href="/Tour/Index" class="btn btn-brand d-flex align-items-center gap-2" style="background-color: #6366f1; color:white; border:none; border-radius: 8px; padding: 10px 20px; text-decoration:none;">
        <i class="bi bi-search"></i>
        <span>Yeni Tur Keşfet</span>
    </a>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="table-card p-4 text-center border-0 shadow-sm bg-white" style="border-radius: 12px;">
            <div class="d-inline-flex p-3 rounded-circle mb-3" style="background: rgba(99, 102, 241, 0.1);">
                <i class="bi bi-calendar-check" style="font-size: 1.5rem; color: #6366f1;"></i>
            </div>
            <div class="text-muted small text-uppercase fw-bold">Onaylanan Turlarım</div>
            <h2 class="mb-0 mt-1 fw-bold">@ViewBag.ActiveCount</h2>
        </div>
    </div>
    <div class="col-md-4">
        <div class="table-card p-4 text-center border-0 shadow-sm bg-white" style="border-radius: 12px;">
            <div class="d-inline-flex p-3 rounded-circle mb-3" style="background: rgba(245, 158, 11, 0.1);">
                <i class="bi bi-hourglass-split" style="font-size: 1.5rem; color: #f59e0b;"></i>
            </div>
            <div class="text-muted small text-uppercase fw-bold">Bekleyen Talepler</div>
            <h2 class="mb-0 mt-1 fw-bold">@ViewBag.PendingCount</h2>
        </div>
    </div>
    <div class="col-md-4">
        <div class="table-card p-4 text-center border-0 shadow-sm bg-white" style="border-radius: 12px;">
            <div class="d-inline-flex p-3 rounded-circle mb-3" style="background: rgba(16, 185, 129, 0.1);">
                <i class="bi bi-list-stars" style="font-size: 1.5rem; color: #10b981;"></i>
            </div>
            <div class="text-muted small text-uppercase fw-bold">Toplam Rezervasyon</div>
            <h2 class="mb-0 mt-1 fw-bold">@ViewBag.TotalCount</h2>
        </div>
    </div>
</div>

<div class="table-card shadow-sm border-0 bg-white" style="border-radius: 12px; overflow: hidden;">
    <div class="table-card-header bg-white p-4 border-bottom">
        <div class="d-flex align-items-center justify-content-between">
            <h5 class="mb-0 fw-bold" style="color: #1a202c;">
                <i class="bi bi-clock-history me-2 text-primary"></i> Son Rezervasyonlarım
            </h5>
            <a href="/Reservation/MyReservations" class="btn btn-sm btn-light text-primary fw-bold">Tümünü Gör</a>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="px-4 py-3">Tur Adı</th>
                    <th class="py-3">Tarih</th>
                    <th class="py-3">Kişi</th>
                    <th class="py-3">Durum</th>
                    <th class="text-end px-4 py-3">İşlem</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="align-middle">
                        <td class="px-4">
                            <div class="d-flex align-items-center">
                                <div class="tour-icon me-3 bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; font-size: 0.8rem;">
                                    <i class="bi bi-geo-alt"></i>
                                </div>
                                <span class="tour-title fw-semibold">@item.TourTitle</span>
                            </div>
                        </td>
                        <td><span class="date-cell"><i class="bi bi-calendar3 me-1"></i> @item.ReservationDate.ToString("dd.MM.yyyy")</span></td>
                        <td><span class="badge rounded-pill bg-light text-dark border">@item.PersonCount Kişi</span></td>
                        <td>
                            @if (item.Status?.ToLower() == "approved")
                            {
                                <span class="badge bg-success text-success bg-opacity-10 p-2 px-3">
                                    <i class="bi bi-check-circle-fill me-1"></i> Onaylandı
                                </span>
                            }
                            else if (item.Status?.ToLower() == "pending")
                            {
                                <span class="badge bg-warning text-warning bg-opacity-10 p-2 px-3">
                                    <i class="bi bi-hourglass-split me-1"></i> Bekliyor
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger text-danger bg-opacity-10 p-2 px-3">
                                    <i class="bi bi-x-circle-fill me-1"></i> Reddedildi
                                </span>
                            }
                        </td>
                        <td class="text-end px-4">
                            <button type="button" class="btn btn-icon btn-sm btn-outline-primary rounded-circle me-2"
                                    onclick="showDetail('@item.ReservationId')" title="Detay">
                                <i class="bi bi-eye"></i>
                            </button>

                            <button type="button" class="btn btn-icon btn-sm btn-outline-danger rounded-circle"
                                    onclick="deleteReservation('@item.ReservationId')" title="İptal Et">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted">Henüz bir rezervasyonunuz bulunmuyor.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Rezervasyon Detay Modal -->
<div class="modal fade" id="resDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 20px; border: none; overflow: hidden;">
            <div class="modal-header border-0 pb-0">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div class="text-center mb-4">
                    <div class="badge bg-primary-soft text-primary mb-2 p-2 px-3" style="background: rgba(99, 102, 241, 0.1); border-radius: 10px;">Rezervasyon Özeti</div>
                    <h4 class="fw-bold" id="m-tourTitle">Tur Adı</h4>
                    <p class="text-muted small" id="m-description">Kısa açıklama buraya gelecek.</p>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-6">
                        <div class="p-3 border rounded-4 bg-light">
                            <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 10px;">Tarih</small>
                            <span class="fw-bold" id="m-date">-</span>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 border rounded-4 bg-light">
                            <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 10px;">Katılımcı</small>
                            <span class="fw-bold" id="m-personCount">-</span>
                        </div>
                    </div>
                </div>

                <div class="guide-card p-3 rounded-4 mb-4" style="background: #f8fafc; border: 1px solid #e2e8f0;">
                    <div class="d-flex align-items-center">
                        <img id="m-guideImage" src="" class="rounded-circle me-3" style="width: 50px; height: 50px; object-fit: cover; border: 2px solid white; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);">
                        <div>
                            <small class="text-primary fw-bold d-block" style="font-size: 11px;">TUR REHBERİNİZ</small>
                            <h6 class="mb-0 fw-bold" id="m-guideName">-</h6>
                            <small class="text-muted" id="m-guideTitle">-</small>
                        </div>
                    </div>
                </div>

                <div class="customer-info border-top pt-3">
                    <h6 class="fw-bold mb-2">İletişim Bilgileriniz</h6>
                    <div class="d-flex justify-content-between small mb-1">
                        <span class="text-muted">Ad Soyad:</span>
                        <span class="fw-bold" id="m-customerName">-</span>
                    </div>
                    <div class="d-flex justify-content-between small">
                        <span class="text-muted">Telefon:</span>
                        <span class="fw-bold" id="m-customerPhone">-</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    function showDetail(resId) {
        console.log("İstek gönderiliyor ID:", resId);

        $.ajax({
            url: '@Url.Action("GetReservationDetail", "Customer")',
            type: 'GET',
            data: { id: resId },
            success: function (data) {
                $("#m-tourTitle").text(data.tourTitle);
                $("#m-description").text(data.description);
                $("#m-date").text(data.date);
                $("#m-personCount").text(data.personCount + " Kişi");
                $("#m-guideName").text(data.guideName);
                $("#m-guideTitle").text(data.guideTitle);
                $("#m-guideImage").attr("src", data.guideImage); // data.guideImage olarak güncelledik
                $("#m-customerName").text(data.customerName);
                $("#m-customerPhone").text(data.customerPhone);

                // Modal'ı aç
                var modalElement = document.getElementById('resDetailModal');
                var myModal = bootstrap.Modal.getOrCreateInstance(modalElement);
                myModal.show();
            },
            error: function (xhr, status, error) {
                console.error("Hata detayı:", xhr.responseText);
                Swal.fire('Hata', 'Bilgiler getirilirken bir sorun oluştu.', 'error');
            }
        });
    }

    function deleteReservation(id) {
        Swal.fire({
            title: 'Emin misiniz?',
            text: "Rezervasyonunuz iptal edilecek!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#64748b',
            confirmButtonText: 'Evet, İptal Et',
            cancelButtonText: 'Vazgeç'
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = "/Customer/DeleteReservation/" + id;
            }
        })
    }
</script>