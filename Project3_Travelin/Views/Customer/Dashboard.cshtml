@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_CustomerLayout.cshtml";
}

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="page-title" style="color: #2d3748; font-weight: 700;">Dashboard</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/Default/Index">Ana Sayfa</a></li>
                <li class="breadcrumb-item active" aria-current="page">Müşteri Paneli</li>
            </ol>
        </nav>
    </div>
    <a href="/Tour/TourList" class="btn btn-brand d-flex align-items-center gap-2" style="background-color: #6366f1; border:none; border-radius: 8px; padding: 10px 20px;">
        <i class="bi bi-search"></i>
        <span>Yeni Tur Keşfet</span>
    </a>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="table-card p-4 text-center border-0 shadow-sm" style="border-radius: 12px;">
            <div class="d-inline-flex p-3 rounded-circle mb-3" style="background: rgba(99, 102, 241, 0.1);">
                <i class="bi bi-calendar-check" style="font-size: 1.5rem; color: #6366f1;"></i>
            </div>
            <div class="text-muted small text-uppercase fw-bold">Aktif Rezervasyonlar</div>
            <h2 class="mb-0 mt-1 fw-bold">2</h2>
        </div>
    </div>
    <div class="col-md-4">
        <div class="table-card p-4 text-center border-0 shadow-sm" style="border-radius: 12px;">
            <div class="d-inline-flex p-3 rounded-circle mb-3" style="background: rgba(16, 185, 129, 0.1);">
                <i class="bi bi-check-all" style="font-size: 1.5rem; color: #10b981;"></i>
            </div>
            <div class="text-muted small text-uppercase fw-bold">Tamamlanan Turlar</div>
            <h2 class="mb-0 mt-1 fw-bold">5</h2>
        </div>
    </div>
    <div class="col-md-4">
        <div class="table-card p-4 text-center border-0 shadow-sm" style="border-radius: 12px;">
            <div class="d-inline-flex p-3 rounded-circle mb-3" style="background: rgba(245, 158, 11, 0.1);">
                <i class="bi bi-star" style="font-size: 1.5rem; color: #f59e0b;"></i>
            </div>
            <div class="text-muted small text-uppercase fw-bold">Toplam Yorumum</div>
            <h2 class="mb-0 mt-1 fw-bold">3</h2>
        </div>
    </div>
</div>

<div class="table-card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
    <div class="table-card-header bg-white p-4 border-bottom">
        <div class="d-flex align-items-center justify-content-between">
            <h5 class="mb-0 fw-bold" style="color: #1a202c;">
                <i class="bi bi-clock-history me-2 text-primary"></i> Son Rezervasyonlarım
            </h5>
            <a href="/Customer/MyReservations" class="btn btn-sm btn-light text-primary fw-bold">Tümünü Gör</a>
        </div>
    </div>
    <div class="table-responsive">
        <table class="tours-table mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="px-4 py-3">Tur Adı</th>
                    <th class="py-3">Tarih</th>
                    <th class="py-3">Kişi</th>
                    <th class="py-3">Durum</th>
                    <th class="text-end px-4 py-3">İşlem</th>
                </tr>
            </thead>
            <tbody>
                <tr class="align-middle">
                    <td class="px-4">
                        <div class="d-flex align-items-center">
                            <div class="tour-icon me-3 bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; font-size: 0.8rem;">
                                <i class="bi bi-geo-alt"></i>
                            </div>
                            <span class="tour-title fw-semibold">Büyük İtalya Turu</span>
                        </div>
                    </td>
                    <td><span class="date-cell"><i class="bi bi-calendar3 me-1"></i> 15.05.2024</span></td>
                    <td><span class="badge rounded-pill bg-light text-dark border">2 Kişi</span></td>
                    <td>
                        <span class="badge bg-success-soft text-success p-2 px-3" style="background: rgba(16, 185, 129, 0.1);">
                            <i class="bi bi-check-circle-fill me-1"></i> Onaylandı
                        </span>
                    </td>
                    <td class="text-end px-4">
                        <a href="#" class="btn btn-icon btn-sm btn-outline-primary rounded-circle" title="Detay">
                            <i class="bi bi-eye"></i>
                        </a>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>