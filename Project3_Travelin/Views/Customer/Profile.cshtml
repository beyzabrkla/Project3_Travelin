@model UpdateUserDTO
@{
    ViewData["Title"] = "Profil Ayarlarım";
    Layout = "~/Views/Shared/_CustomerLayout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card border-0 shadow-lg" style="background: #1a1a1a; border-radius: 24px; border: 1px solid rgba(217, 70, 239, 0.2);">
                <div class="card-header bg-transparent border-0 text-center pt-5">
                    <div class="mb-3 d-inline-block p-4 rounded-circle" style="background: rgba(217, 70, 239, 0.05);">
                        <i class="bi bi-person-circle" style="font-size: 3.5rem; color: #d946ef;"></i>
                    </div>
                    <h3 class="text-white fw-bold">Profil Bilgileri</h3>
                </div>

                <div class="card-body px-5 pb-5">
                    @* Formun doğru aksiyona POST attığından emin oluyoruz *@
                    <form asp-action="Profile" asp-controller="Customer" method="post">
                        <div class="mb-4">
                            <label class="form-label small fw-bold text-pink">AD SOYAD</label>
                            <input type="text" asp-for="FullName" class="form-control custom-input">
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold text-pink">KULLANICI ADI</label>
                            <input type="text" asp-for="UserName" class="form-control custom-input" readonly style="opacity: 0.5;">
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label class="form-label small fw-bold text-pink">E-POSTA</label>
                                <input type="email" asp-for="Email" class="form-control custom-input">
                            </div>
                            <div class="col-md-6 mb-4">
                                <label class="form-label small fw-bold text-pink">TELEFON</label>
                                <input type="text" asp-for="PhoneNumber" class="form-control custom-input">
                            </div>
                        </div>

                        <button type="submit" class="btn btn-brand w-100 py-3 fw-bold" style="background: #d946ef; color: white; border-radius: 12px;">
                            GÜNCELLE
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @if (TempData["ProfileUpdateSuccess"] != null)
    {
        <script>
            Swal.fire({
                icon: 'success',
                title: 'Güncellendi!',
                background: '#1a1a1a',
                color: '#fff',
                confirmButtonColor: '#d946ef'
            });
        </script>
    }
}

<style>
    .text-pink {
        color: #d946ef;
    }

    .custom-input {
        background: rgba(255,255,255,0.05) !important;
        border: 1px solid rgba(255,255,255,0.1) !important;
        color: white !important;
        border-radius: 12px;
        padding: 12px;
    }

        .custom-input:focus {
            border-color: #d946ef !important;
            box-shadow: 0 0 10px rgba(217, 70, 239, 0.2);
        }
</style>