@model List<ResultTourDTO>
@{
    ViewData["Title"] = "Turlarım";
    Layout = "~/Views/Shared/_CustomerLayout.cshtml";
}

<div class="page-header mb-4">
    <div>
        <h1 class="page-title">Turlarım</h1>
        <p class="text-muted mt-1">
            Hoş geldiniz, <strong>@ViewBag.GuideName</strong> — size atanmış turları aşağıda görebilirsiniz.
        </p>
    </div>
</div>

@* İSTATİSTİK KARTLARI *@
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg-4">
        <div class="card border-0 shadow-sm rounded-3 p-3 d-flex flex-row align-items-center gap-3">
            <div class="rounded-3 p-3" style="background:rgba(93,4,115,0.1);">
                <i class="bi bi-map fs-4" style="color:#5d0473;"></i>
            </div>
            <div>
                <div class="fw-bold fs-4">@ViewBag.TourCount</div>
                <div class="text-muted small">Toplam Tur</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-4">
        <div class="card border-0 shadow-sm rounded-3 p-3 d-flex flex-row align-items-center gap-3">
            <div class="rounded-3 p-3" style="background:rgba(22,163,74,0.1);">
                <i class="bi bi-check-circle fs-4" style="color:#16a34a;"></i>
            </div>
            <div>
                <div class="fw-bold fs-4">@ViewBag.ActiveTourCount</div>
                <div class="text-muted small">Aktif Tur</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-4">
        <div class="card border-0 shadow-sm rounded-3 p-3 d-flex flex-row align-items-center gap-3">
            <div class="rounded-3 p-3" style="background:rgba(234,179,8,0.1);">
                <i class="bi bi-calendar-event fs-4" style="color:#ca8a04;"></i>
            </div>
            <div>
                <div class="fw-bold fs-4">
                    @(Model?.Where(x => x.TourDate >= DateTime.Now).Count() ?? 0)
                </div>
                <div class="text-muted small">Yaklaşan Tur</div>
            </div>
        </div>
    </div>
</div>

@* TUR LİSTESİ *@
@if (Model == null || !Model.Any())
{
    <div class="card border-0 shadow-sm rounded-3 p-5 text-center">
        <i class="bi bi-map fs-1 text-muted mb-3"></i>
        <h5 class="text-muted">Henüz size atanmış bir tur bulunmuyor.</h5>
        <p class="text-muted small">Admin tarafından bir tur atandığında burada görüntülenecek.</p>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var tour in Model.OrderByDescending(x => x.TourDate))
        {
            @* Durum badge'i hesapla *@
            string badgeClass = "secondary";
            string badgeText = "Pasif";
            if (tour.IsDrafts) { badgeClass = "warning text-dark"; badgeText = "Taslak"; }
            else if (tour.IsStatus) { badgeClass = "success"; badgeText = "Aktif"; }

            <div class="col-md-6 col-xl-4">
                <div class="card border-0 shadow-sm rounded-3 overflow-hidden h-100">

                    @* Tur Görseli *@
                    <div style="height:180px; background-image:url('@tour.ImageUrl'); background-size:cover; background-position:center; position:relative;">
                        <span class="badge bg-@badgeClass position-absolute top-0 end-0 m-2 px-2 py-1">
                            @badgeText
                        </span>
                    </div>

                    <div class="card-body p-3">
                        <h6 class="fw-bold mb-1">@tour.TourTitle</h6>
                        <p class="text-muted small mb-2">
                            <i class="bi bi-geo-alt me-1"></i>@tour.TourCity, @tour.TourCountry
                        </p>
                        <p class="text-muted small mb-0 text-truncate">@tour.SubDescription</p>
                    </div>

                    <div class="card-footer bg-white border-0 p-3 pt-0">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="small text-muted">
                                <i class="bi bi-calendar3 me-1"></i>@tour.TourDate.ToString("dd MMM yyyy")
                            </span>
                            <span class="small text-muted">
                                <i class="bi bi-clock me-1"></i>@tour.DayNight
                            </span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="small text-muted">
                                <i class="bi bi-people me-1"></i>@tour.TourCapacity Kişi
                            </span>
                            <span class="fw-bold" style="color:#5d0473;">
                                @tour.TourPrice.ToString("N0") ₺
                            </span>
                        </div>
                        <div class="d-flex gap-2">
                            <a href="/Guide/GuideTourLog/@tour.TourId"
                               class="btn btn-sm btn-outline-secondary flex-fill rounded-pill">
                                <i class="bi bi-journal-text me-1"></i>Gezi Günlüğü
                            </a>
                            <a href="/Tour/GuideTourLog/@tour.TourId"
                               class="btn btn-sm text-white flex-fill rounded-pill"
                               style="background:#5d0473;">
                                <i class="bi bi-eye me-1"></i>Tur Detayı
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
