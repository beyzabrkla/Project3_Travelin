@using DTOLayer.DTOs.GuideDTOs
@model List<ResultGuideDTO>

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Rehber Yönetimi</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="container mt-5">

    <div class="card shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
            <h4 class="m-0 font-weight-bold text-primary"><i class="fas fa-users-cog me-2"></i>Rehber Yönetim Paneli</h4>
            <a href="/AdminGuide/CreateGuide" class="btn btn-success btn-sm">
                <i class="fas fa-plus me-1"></i> Yeni Rehber Ekle
            </a>
        </div>
        <div class="card-body">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width: 80px;">Profil</th>
                        <th>Ad Soyad</th>
                        <th>Unvan</th>
                        <th class="text-center">Durum</th>
                        <th class="text-center" style="width: 250px;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <img src="@item.ImageUrl" class="rounded-circle border shadow-sm" style="width:50px; height:50px; object-fit:cover;" onerror="this.src='https://via.placeholder.com/50'" />
                                </td>
                                <td class="fw-bold">@item.Name</td>
                                <td><span class="text-muted">@item.Title</span></td>
                                <td class="text-center">
                                    @if (item.Status)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success px-3">Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger px-3">Pasif</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @* Durum Değiştirme Butonu *@
                                    <a href="/Guide/ChangeStatus/@item.GuideId" class="btn @(item.Status ? "btn-outline-secondary" : "btn-outline-primary") btn-sm me-2">
                                        <i class="fas @(item.Status ? "fa-user-slash" : "fa-user-check") me-1"></i>
                                        @(item.Status ? "Pasif Yap" : "Aktif Yap")
                                    </a>

                                    @* Güncelleme Butonu *@
                                    <a href="/Guide/UpdateGuide/@item.GuideId" class="btn btn-outline-warning btn-sm">
                                        <i class="fas fa-edit me-1"></i> Düzenle
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="fas fa-info-circle me-2"></i>Henüz bir rehber kaydı bulunamadı.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</body>
</html>