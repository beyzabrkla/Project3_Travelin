@model CreateTourDTO
@{
    Layout = null;
}

<link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container">
    <br /><br />
    <form method="post">
        <label>Tur Başlığı </label>
        <input type="text" asp-for="TourTitle" class="form-control" />
        <br />
        <label>Şehir </label>
        <input type="text" asp-for="TourCity" class="form-control" />
        <br />
        <label>Ülke </label>
        <input type="text" asp-for="TourCountry" class="form-control" />
        <br />
        <label>Açıklama </label>
        <input type="text" asp-for="SubDescription" class="form-control" />
        <br />
        <label>Kapasite </label>
        <input type="number" asp-for="TourCapacity" class="form-control" />
        <br />      
        <label>Gece-Gündüz</label>
        <input type="text" asp-for="DayNight" class="form-control" />
        <br />
        <label> Tur Tarihi</label>
        <input type="date" asp-for="TourDate" class="form-control" />
        <br />
        <button class="btn btn-primary">Turu Kaydet</button>
    </form>
</div>
