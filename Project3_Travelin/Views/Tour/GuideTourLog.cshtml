@model DTOLayer.DTOs.TourDTOs.GetTourByIdDTO
@{
    ViewData["Title"] = "Rehberin Gezi Günlüğü";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="guide-log-header py-5" style="background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('@Model.ImageUrl') no-repeat center; background-size: cover; min-height: 400px; display: flex; align-items: center;">
    <div class="container text-center text-white">
        <h1 class="display-4 fw-bold text-light">@Model.TourTitle</h1>
        <p class="lead">Rehberimiz <span class="fw-bold text-warning">@Model.GuideName</span> Kadrajından ve Kaleminden</p>
    </div>
</section>

<section class="guide-content py-5 bg-white">
    <div class="container">
        <div class="row">
            @* SOL TARAF: BLOG İÇERİĞİ *@
            <div class="col-lg-8">
                <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
                    <img src="@(string.IsNullOrEmpty(Model.GuideImageUrl) ? "/images/default-guide.png" : Model.GuideImageUrl)"
                         class="rounded-circle me-3 shadow" style="width: 90px; height: 90px; object-fit: cover; border: 3px solid #fff;">
                    <div>
                        <h4 class="mb-0 fw-bold">@Model.GuideName</h4>
                        <span class="text-theme">@Model.GuideTitle</span>
                    </div>
                </div>

                <div class="blog-text-area mb-5">
                    <h3 class="fw-bold mb-4"><i class="fa fa-pen-nib me-2 theme"></i>Bu Rota Hakkında Ne Düşünüyorum?</h3>
                    <div class="p-4 rounded-3 shadow-sm bg-light border-start border-5 border-theme">
                        @if (!string.IsNullOrEmpty(Model.GuideDescription))
                        {
                            <p class="lead fst-italic text-dark mb-0" style="line-height: 1.8;">
                                "@Model.GuideDescription"
                            </p>
                        }
                        else
                        {
                            <p class="text-muted italic">Rehberimiz bu rota için henüz kişisel notlarını eklememiş.</p>
                        }
                    </div>
                </div>

                @* REHBERİN FOTOĞRAFLARI *@
                <div class="gallery-area">
                    <h4 class="fw-bold mb-4"><i class="fa fa-camera-retro me-2 theme"></i>Rehberimizin Kadrajından Görüntüler</h4>
                    <div class="row g-3">
                        @if (Model.ImageAlbumUrls != null && Model.ImageAlbumUrls.Any())
                        {
                            foreach (var img in Model.ImageAlbumUrls)
                            {
                                <div class="col-md-6">
                                    <div class="gallery-card overflow-hidden rounded-3 shadow-sm" style="height: 250px;">
                                        <img src="@img" class="w-100 h-100" style="object-fit: cover;">
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="col-12">
                                <div class="alert alert-secondary text-center">Rehber henüz fotoğraf yüklememiş.</div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            @* SAĞ TARAF: TEKNİK ÖZET (SABİT) *@
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm sticky-top" style="top: 100px; border-radius: 20px;">
                    <div class="card-body p-4 text-center">
                        <h5 class="fw-bold border-bottom pb-3 mb-4">Turun Künyesi</h5>

                        <div class="info-list text-start mb-4">
                            <div class="d-flex align-items-center mb-3">
                                <div class="icon-box me-3 theme bg-light p-2 rounded">
                                    <i class="fa fa-map-marker-alt"></i>
                                </div>
                                <span>@Model.TourCity, @Model.TourCountry</span>
                            </div>
                            <div class="d-flex align-items-center mb-3">
                                <div class="icon-box me-3 theme bg-light p-2 rounded">
                                    <i class="fa fa-calendar-alt"></i>
                                </div>
                                <span>@Model.TourDate.ToString("dd MMMM yyyy")</span>
                            </div>
                            <div class="d-flex align-items-center mb-3">
                                <div class="icon-box me-3 theme bg-light p-2 rounded">
                                    <i class="fa fa-users"></i>
                                </div>
                                <span>@Model.TourCapacity Kişi Kapasite</span>
                            </div>
                        </div>

                        <div class="price-box bg-theme text-white p-3 rounded-pill mb-4 shadow" style="background-color: #6a008a";>
                            <span class="small d-block">Tur Fiyatı</span>
                            <h3 class="fw-bold mb-0 text-light">@Model.TourPrice.ToString("C2")</h3>
                        </div>

                        <a href="/Tour/TourDetail/@Model.TourId" class="btn btn-outline-dark w-100 rounded-pill py-2">
                            <i class="fa fa-arrow-left me-2"></i>Resmi Tur Sayfasına Git
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>