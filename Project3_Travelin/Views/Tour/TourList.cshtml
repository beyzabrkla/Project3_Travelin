@model List<ResultTourDTO>
@{
    ViewData["Title"] = "View";
    Layout = "~/Views/Shared/_Layout.cshtml";

    int currentPage = ViewBag.CurrentPage ?? 1;
    int pageSize = ViewBag.PageSize ?? 3;
    int totalTours = ViewBag.TotalTours ?? 0;

    int startRange = totalTours == 0 ? 0 : ((currentPage - 1) * pageSize) + 1;
    int endRange = currentPage * pageSize;

    if (endRange > totalTours) { endRange = totalTours; }
}

<section class="breadcrumb-main pb-20 pt-14" style="background-image: url(/travelin/images/bg/bg1.jpg);">
    <div class="section-shape section-shape1 top-inherit bottom-0" style="background-image: url(/travelin/images/shape8.png);"></div>
    <div class="breadcrumb-outer">
        <div class="container">
            <div class="breadcrumb-content text-center">
                <h1 class="mb-3">TUR LİSTESİ</h1>
                <nav aria-label="breadcrumb" class="d-block">
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/">Ana Sayfa</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Güncel Tur Listesi</li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
    <div class="dot-overlay"></div>
</section>

<section class="trending pt-6 pb-0 bg-lgrey">
    <div class="container">
        <div class="visa-filter-tabs text-center mb-5">
            <div class="filter-wrapper shadow-sm p-2 bg-white rounded-pill d-inline-block">
                <a href="/Tour/TourList?destination=@ViewBag.Destination&duration=@ViewBag.Duration"
                   class="btn-visa-filter @(ViewBag.VisaStatus == null ? "active" : "")">
                    <i class="fa fa-globe me-2"></i>Tümü
                </a>

                <a href="/Tour/TourList?visaStatus=false&destination=@ViewBag.Destination&duration=@ViewBag.Duration"
                   class="btn-visa-filter @(ViewBag.VisaStatus != null && (bool)ViewBag.VisaStatus == false ? "active" : "")">
                    <i class="fa fa-passport me-2"></i>Vizesiz
                </a>

                <a href="/Tour/TourList?visaStatus=true&destination=@ViewBag.Destination&duration=@ViewBag.Duration"
                   class="btn-visa-filter @(ViewBag.VisaStatus != null && (bool)ViewBag.VisaStatus == true ? "active" : "")">
                    <i class="fa fa-id-card me-2"></i>Vize Gerekenler
                </a>
            </div>
        </div>
        <div class="list-results d-flex align-items-center justify-content-between">
            <div class="list-results-sort">
                @if (totalTours > 0)
                {
                    <p class="m-0">Toplam <b>@totalTours</b> sonuçtan <b>@startRange - @endRange</b> arası gösteriliyor</p>
                }
                else
                {
                    <p class="m-0">Görüntülenecek aktif tur bulunamadı.</p>
                }
            </div>
        </div>

        <div class="destination-list">
            @foreach (var x in Model)
            {
                @* Sadece Aktif Turları Göster *@
                if (x.IsStatus == true)
                {
                    <div class="trend-full bg-white rounded box-shadow overflow-hidden p-4 mb-4">
                        <div class="row">
                            <div class="col-lg-4 col-md-3">
                                <div class="trend-item2 rounded">
                                    <a href="/Tour/TourDetail/@x.TourId" style="background-image: url(@x.ImageUrl);"></a>
                                    <div class="color-overlay"></div>
                                </div>
                            </div>
                            <div class="col-lg-5 col-md-6">
                                <div class="trend-content position-relative text-md-start text-center">
                                    <small>@x.DayNight</small>
                                    <h3 class="mb-1"><a href="/Tour/TourDetail/@x.TourId">@x.TourTitle</a></h3>
                                    <h6 class="theme mb-0"><i class="icon-location-pin"></i> @x.TourCountry</h6>
                                    <p class="mt-4 mb-0">@x.SubDescription <br><a href="#"><span class="theme"> Ücretsiz İptal</span></a></p>
                                </div>
                            </div>
                            <div class="col-lg-3 col-md-3">
                                <div class="trend-content text-md-end text-center">
                                    <div class="rating">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= x.Rating)
                                            {
                                                <span class="fa fa-star checked text-warning"></span>
                                            }
                                            else
                                            {
                                                <span class="fa fa-star text-muted"></span>
                                            }
                                        }
                                    </div>

                                    <small>@x.ReviewCount Değerlendirme</small>
                                    <div class="trend-price my-2">
                                        <h3 class="mb-0">@x.TourPrice ₺</h3>
                                        <small>Kişi Başı</small>
                                    </div>
                                    <a href="/Tour/TourDetail/@x.TourId" class="nir-btn">Detay</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }

            @* Sayfalama Alanı *@
            <div class="text-center mt-4">
                @if (ViewBag.CurrentPage > 1)
                {
                    <a href="?page=@(ViewBag.CurrentPage - 1)&destination=@ViewBag.Destination&duration=@ViewBag.Duration" class="nir-btn me-2">
                        <i class="fa fa-long-arrow-alt-left"></i> Önceki
                    </a>
                }

                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <a href="?page=@i&destination=@ViewBag.Destination&duration=@ViewBag.Duration"
                       class="nir-btn me-1 @(i == ViewBag.CurrentPage ? "active" : "")">
                        @i
                    </a>
                }

                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <a href="?page=@(ViewBag.CurrentPage + 1)&destination=@ViewBag.Destination&duration=@ViewBag.Duration" class="nir-btn ms-2">
                        Sonraki <i class="fa fa-long-arrow-alt-right"></i>
                    </a>
                }
            </div>
        </div>
    </div>
</section>

<style>
    /* Filtre Konteynırı */
    .filter-wrapper {
        border: 1px solid #f0f0f0;
    }

    /* Temel Buton Tasarımı */
    .btn-visa-filter {
        display: inline-block;
        padding: 10px 25px;
        border-radius: 50px;
        text-decoration: none;
        color: #666; /* Pasif yazı rengi */
        font-weight: 600;
        font-size: 14px;
        transition: all 0.3s ease;
        border: 2px solid transparent;
    }

        /* Hover Durumu */
        .btn-visa-filter:hover {
            color: #5d0473;
            background-color: #fcf4ff;
        }

        /* Aktif (Seçili) Buton - Senin Tema Rengin */
        .btn-visa-filter.active {
            background-color: #5d0473; /* Tema Moru */
            color: white !important;
            box-shadow: 0 4px 15px rgba(93, 4, 115, 0.3);
        }

    /* Kart Üzerindeki Badge'leri de Temaya Uyduralım */
    .badge.bg-success {
        background-color: #28a745 !important; /* Doğayı ve onayı temsilen yeşil kalsın ama tonu yumuşasın */
    }

    .badge.bg-danger {
        background-color: #a30000 !important; /* Çok parlak kırmızı yerine daha oturaklı bir kırmızı */
    }
</style>