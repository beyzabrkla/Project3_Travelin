<style>
    #termsModal, #privacyModal, #adminTermsModal, #adminPrivacyModal {
        z-index: 1070 !important;
    }

    .modal-stack-fix {
        background: rgba(0,0,0,0.2) !important;
    }
</style>

@* Toast bildirimleri *@
@if (TempData["LoginError"] != null)
{
    <div class="position-fixed bottom-0 end-0 m-3" style="z-index:9999;">
        <div class="toast show align-items-center text-white bg-danger border-0 shadow">
            <div class="d-flex">
                <div class="toast-body"><i class="bi bi-exclamation-circle me-2"></i>@TempData["LoginError"]</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>
}
@if (TempData["RegisterError"] != null)
{
    <div class="position-fixed bottom-0 end-0 m-3" style="z-index:9999;">
        <div class="toast show align-items-center text-white bg-danger border-0 shadow">
            <div class="d-flex">
                <div class="toast-body"><i class="bi bi-exclamation-circle me-2"></i>@TempData["RegisterError"]</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>
}
@if (TempData["RegisterSuccess"] != null)
{
    <div class="position-fixed bottom-0 end-0 m-3" style="z-index:9999;">
        <div class="toast show align-items-center text-white bg-success border-0 shadow">
            <div class="d-flex">
                <div class="toast-body"><i class="bi bi-check-circle me-2"></i>@TempData["RegisterSuccess"]</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>
}

<!-- ============= KULLANICI GİRİŞ/ÜYE OL MODAL ============= -->
<div class="modal fade log-reg" id="exampleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-body">
                <div class="post-tabs">
                    <ul class="nav nav-tabs nav-pills nav-fill" id="postsTab" role="tablist">
                        <li class="nav-item">
                            <button class="nav-link @(TempData["RegisterError"] != null ? "" : "active")"
                                    data-bs-target="#login" data-bs-toggle="tab" type="button">
                                Giriş Yap
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link @(TempData["RegisterError"] != null ? "active" : "")"
                                    data-bs-target="#register" data-bs-toggle="tab" type="button">
                                Üye Ol
                            </button>
                        </li>
                    </ul>
                    <div class="tab-content blog-full" id="postsTabContent">

                        @*--- LOGIN ---*@
                        <div class="tab-pane fade @(TempData["RegisterError"] != null ? "" : "active show")"
                             id="login" role="tabpanel">
                            <div class="row">
                                <div class="col-lg-6">
                                    <div class="blog-image rounded">
                                        <a href="#" style="background-image: url(/travelin/images/giris.png)"></a>
                                    </div>
                                </div>
                                <div class="col-lg-6">
                                    <h4 class="text-center border-b pb-2">Giriş Yap</h4>

                                    @if (TempData["LoginError"] != null)
                                    {
                                        <div class="alert alert-danger py-2 small mb-2">
                                            <i class="bi bi-exclamation-circle me-1"></i>@TempData["LoginError"]
                                        </div>
                                    }

                                    <div class="log-reg-button d-flex align-items-center justify-content-between">
                                        <button type="button" class="btn btn-fb"><i class="fab fa-facebook"></i> Facebook ile Giriş Yap</button>
                                        <button type="button" class="btn btn-google"><i class="fab fa-google"></i> Google ile Giriş Yap</button>
                                    </div>
                                    <hr class="log-reg-hr position-relative my-4 overflow-visible" />

                                    <form method="post" action="/Login/Login">
                                        @Html.AntiForgeryToken()
                                        <div class="form-group mb-2">
                                            <input type="text" name="user_name" class="form-control"
                                                   placeholder="Kullanıcı Adı veya E-posta..." required />
                                        </div>
                                        <div class="form-group mb-2">
                                            <input type="password" name="password_name" class="form-control"
                                                   placeholder="Şifreniz..." required />
                                        </div>
                                        <div class="comment-btn mb-2 pb-2">
                                            <input type="submit" class="nir-btn w-100" value="Giriş Yap" />
                                        </div>
                                    </form>

                                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                                    {
                                        <div class="text-center small mt-1">
                                            <span class="text-muted">@User.Identity.Name olarak giriş yaptınız.</span>
                                            <a href="/Login/Logout" class="text-danger ms-2 fw-bold">Çıkış Yap</a>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        @*--- REGISTER ---*@
                        <div class="tab-pane fade @(TempData["RegisterError"] != null ? "active show" : "")"
                             id="register" role="tabpanel">
                            <div class="row">
                                <div class="col-lg-6">
                                    <div class="blog-image rounded">
                                        <a href="#" style="background-image: url(/travelin/images/kayitol.png)"></a>
                                    </div>
                                </div>
                                <div class="col-lg-6">
                                    <h4 class="text-center border-b pb-2">Üye Ol</h4>

                                    @if (TempData["RegisterError"] != null)
                                    {
                                        <div class="alert alert-danger py-2 small mb-2">
                                            <i class="bi bi-exclamation-circle me-1"></i>@TempData["RegisterError"]
                                        </div>
                                    }

                                    <form method="post" action="/Login/Register">
                                        @Html.AntiForgeryToken()
                                        <div class="form-group mb-2">
                                            <input type="text" name="user_name" class="form-control"
                                                   placeholder="Kullanıcı Adınız..." required />
                                        </div>
                                        <div class="form-group mb-2">
                                            <input type="email" name="user_email" class="form-control"
                                                   placeholder="E-posta Adresiniz..." required />
                                        </div>
                                        <div class="form-group mb-2">
                                            <input type="password" name="password_name" class="form-control"
                                                   placeholder="Şifreniz..." required minlength="6" />
                                        </div>
                                        <div class="form-group mb-2">
                                            <input type="password" name="repassword_name" class="form-control"
                                                   placeholder="Şifre Tekrar..." required minlength="6" />
                                        </div>
                                        <div class="form-group mb-2 d-flex align-items-start">
                                            <input type="checkbox" class="mt-1" id="exampleCheck1" required />
                                            <label class="mb-0 ms-1" for="exampleCheck1" style="font-size:13px;">
                                                <a href="#" data-bs-toggle="modal" data-bs-target="#termsModal"
                                                   class="theme fw-bold">Kullanım Şartları</a> ve
                                                <a href="#" data-bs-toggle="modal" data-bs-target="#privacyModal"
                                                   class="theme fw-bold">Gizlilik Politikası</a>'nı okudum.
                                            </label>
                                        </div>
                                        <div class="comment-btn mb-2 pb-2">
                                            <input type="submit" class="nir-btn w-100" value="Kayıt Ol" />
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

