<!-- ============= KULLANICI MODALLARI ============= -->
<!-- Kullanıcı - Kullanım Şartları Modal -->
<div class="modal fade modal-stack-fix" id="termsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-theme">
                <h5 class="modal-title text-white">Kullanım Şartları</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Kullanım şartları içeriği buraya gelecek...</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="nir-btn" onclick="closeSubModal()">Okudum, Kabul Ediyorum</button>
            </div>
        </div>
    </div>
</div>

<!-- Kullanıcı - Gizlilik Politikası Modal -->
<div class="modal fade modal-stack-fix" id="privacyModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-theme">
                <h5 class="modal-title text-white">Gizlilik Politikası</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Gizlilik politikası içeriği buraya gelecek...</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="nir-btn" onclick="closeSubModal()">Okudum, Kabul Ediyorum</button>
            </div>
        </div>
    </div>
</div>

<!-- ============= ADMIN MODALLARI ============= -->
<!-- Admin - Kullanım Şartları Modal -->
<div class="modal fade modal-stack-fix" id="adminTermsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-theme">
                <h5 class="modal-title text-white">Kullanım Şartları (Admin)</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Admin Kullanım şartları içeriği buraya gelecek...</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="nir-btn" onclick="closeAdminSubModal()">Okudum, Kabul Ediyorum</button>
            </div>
        </div>
    </div>
</div>

<!-- Admin - Gizlilik Politikası Modal -->
<div class="modal fade modal-stack-fix" id="adminPrivacyModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-theme">
                <h5 class="modal-title text-white">Gizlilik Politikası (Admin)</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Admin Gizlilik politikası içeriği buraya gelecek...</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="nir-btn" onclick="closeAdminSubModal()">Okudum, Kabul Ediyorum</button>
            </div>
        </div>
    </div>
</div>

<script>
    function closeSubModal() {
        const termsModal = bootstrap.Modal.getInstance(document.getElementById('termsModal'));
        const privacyModal = bootstrap.Modal.getInstance(document.getElementById('privacyModal'));
        if (termsModal) termsModal.hide();
        if (privacyModal) privacyModal.hide();
        setTimeout(() => {
            if (document.querySelector('#exampleModal.show')) {
                document.body.classList.add('modal-open');
                document.body.style.overflow = 'hidden';
                document.body.style.paddingRight = '17px';
            }
        }, 400);
    }

    function closeAdminSubModal() {
        const adminTermsModal = bootstrap.Modal.getInstance(document.getElementById('adminTermsModal'));
        const adminPrivacyModal = bootstrap.Modal.getInstance(document.getElementById('adminPrivacyModal'));
        if (adminTermsModal) adminTermsModal.hide();
        if (adminPrivacyModal) adminPrivacyModal.hide();
        setTimeout(() => {
            if (document.querySelector('#adminModal.show')) {
                document.body.classList.add('modal-open');
                document.body.style.overflow = 'hidden';
                document.body.style.paddingRight = '17px';
            }
        }, 400);
    }

    document.addEventListener('hidden.bs.modal', function () {
        if (document.querySelectorAll('.modal.show').length > 0) {
            document.body.classList.add('modal-open');
        }
    });

    // Hata varsa modal'ı otomatik aç
    @if (TempData["LoginError"] != null || TempData["RegisterError"] != null)
    {
            <text>
                document.addEventListener('DOMContentLoaded', function () {
                    var loginModal = new bootstrap.Modal(document.getElementById('exampleModal'));
                    loginModal.show();
                });
            </text>
    }

    @if (TempData["AdminLoginError"] != null || TempData["AdminRegisterError"] != null)
    {
            <text>
                document.addEventListener('DOMContentLoaded', function () {
                    var adminModal = new bootstrap.Modal(document.getElementById('adminModal'));
                    adminModal.show();
                });
            </text>
    }

    // Toast'ları 4 saniye sonra kapat
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('.toast').forEach(function (el) {
            setTimeout(function () {
                el.closest('.position-fixed')?.remove();
            }, 4000);
        });
    });
</script>
