<style>
    /* Üst üste binen modalların birbirini ezmemesi için */
    #termsModal, #privacyModal {
        z-index: 1070 !important;
    }
    /* İkinci karartmanın ekranı tamamen siyah yapmasını engeller */
    .modal-stack-fix {
        background: rgba(0,0,0,0.2) !important;
    }
</style>

<div class="modal fade log-reg" id="exampleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-body">
                <div class="post-tabs">
                    <ul class="nav nav-tabs nav-pills nav-fill" id="postsTab" role="tablist">
                        <li class="nav-item">
                            <button class="nav-link active" data-bs-target="#login" data-bs-toggle="tab" type="button">Giriş Yap</button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link" data-bs-target="#register" data-bs-toggle="tab" type="button">Üye Ol</button>
                        </li>
                    </ul>
                    <div class="tab-content blog-full" id="postsTabContent">
                        @*--- LOGIN ---*@
                        <div class="tab-pane fade active show" id="login" role="tabpanel">
                            <div class="row">
                                <div class="col-lg-6">
                                    <div class="blog-image rounded">
                                        <a href="#" style="background-image: url(/travelin/images/trending/trending5.jpg)"></a>
                                    </div>
                                </div>
                                <div class="col-lg-6">
                                    <h4 class="text-center border-b pb-2">Login</h4>
                                    <div class="log-reg-button d-flex align-items-center justify-content-between">
                                        <button type="button" class="btn btn-fb"><i class="fab fa-facebook"></i> Facebook</button>
                                        <button type="button" class="btn btn-google"><i class="fab fa-google"></i> Google</button>
                                    </div>
                                    <hr class="log-reg-hr position-relative my-4 overflow-visible" />
                                    <form method="post" action="/Login/Login">
                                        <div class="form-group mb-2"><input type="text" name="user_name" class="form-control" placeholder="Kullanıcı Adınız..." /></div>
                                        <div class="form-group mb-2"><input type="password" name="password_name" class="form-control" placeholder="Şifreniz...." /></div>
                                        <div class="comment-btn mb-2 pb-2"><input type="submit" class="nir-btn w-100" value="Login" /></div>
                                    </form>
                                </div>
                            </div>
                        </div>

                        @*--- REGISTER (Eksikler Eklendi) ---*@
                        <div class="tab-pane fade" id="register" role="tabpanel">
                            <div class="row">
                                <div class="col-lg-6">
                                    <div class="blog-image rounded">
                                        <a href="#" style="background-image: url(/travelin/images/trending/trending5.jpg)"></a>
                                    </div>
                                </div>
                                <div class="col-lg-6">
                                    <h4 class="text-center border-b pb-2">Üye Ol</h4>
                                    <form method="post" action="/Login/Register">
                                        <div class="form-group mb-2">
                                            <input type="text" name="user_name" class="form-control" placeholder="Kullanıcı Adınız..." required />
                                        </div>
                                        <div class="form-group mb-2">
                                            <input type="email" name="user_email" class="form-control" placeholder="E-posta Adresiniz..." required />
                                        </div>
                                        <div class="form-group mb-2">
                                            <input type="password" name="password_name" class="form-control" placeholder="Şifreniz..." required />
                                        </div>
                                        <div class="form-group mb-2">
                                            <input type="password" name="repassword_name" class="form-control" placeholder="Şifre Tekrar..." required />
                                        </div>

                                        <div class="form-group mb-2 d-flex align-items-start">
                                            <input type="checkbox" class="mt-1" id="exampleCheck1" required />
                                            <label class="mb-0 ms-1" for="exampleCheck1" style="font-size: 13px;">
                                                @* Buradaki data-bs-toggle="modal" arkadakini kapatmasın diye sadece target kullanıyoruz *@
                                                <a href="#" data-bs-toggle="modal" data-bs-target="#termsModal" class="theme fw-bold">Kullanım Şartları</a> ve
                                                <a href="#" data-bs-toggle="modal" data-bs-target="#privacyModal" class="theme fw-bold">Gizlilik Politikası</a>'nı okudum.
                                            </label>
                                        </div>
                                        <div class="comment-btn mb-2 pb-2"><input type="submit" class="nir-btn w-100" value="Kayıt Ol" /></div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade modal-stack-fix" id="termsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-theme">
                <h5 class="modal-title text-white">Kullanım Şartları</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Kullanım şartları içeriği buraya gelecek...</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="nir-btn" onclick="closeSubModal()">Okudum, Kabul Ediyorum</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade modal-stack-fix" id="privacyModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-theme">
                <h5 class="modal-title text-white">Gizlilik Politikası</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Gizlilik politikası içeriği buraya gelecek...</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="nir-btn" onclick="closeSubModal()">Okudum, Kabul Ediyorum</button>
            </div>
        </div>
    </div>
</div>

<script>
    function closeSubModal() {
        // 1. Önce açık olan alt modalı (terms veya privacy) kapat
        const termsModal = bootstrap.Modal.getInstance(document.getElementById('termsModal'));
        const privacyModal = bootstrap.Modal.getInstance(document.getElementById('privacyModal'));

        if (termsModal) termsModal.hide();
        if (privacyModal) privacyModal.hide();

        // 2. Çok kısa bir bekleme sonrası (animasyon biterken) body'yi düzelt
        setTimeout(() => {
            // Eğer hala ana modal (exampleModal) açıksa body sınıfını geri yükle
            if (document.querySelector('#exampleModal.show')) {
                document.body.classList.add('modal-open');
                // Ekranın kaymasını önlemek için bootstrap'in eklediği padding'i koru
                document.body.style.overflow = 'hidden';
                document.body.style.paddingRight = '17px'; // Scroll bar genişliği
            }
        }, 400);
    }

    // Ekstra Önlem: Herhangi bir modal kapandığında arka planda başka modal varsa body'yi kilitle
    document.addEventListener('hidden.bs.modal', function () {
        if (document.querySelectorAll('.modal.show').length > 0) {
            document.body.classList.add('modal-open');
        }
    });</script>