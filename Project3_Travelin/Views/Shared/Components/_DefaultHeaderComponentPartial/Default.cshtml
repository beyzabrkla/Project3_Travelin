<header class="main_header_area">
    <div class="header-content py-1 bg-theme">
        <div class="container d-flex align-items-center justify-content-between">
            <div class="links">
                <ul>
                    <li><a href="#" class="white"><i class="icon-calendar white"></i> @DateTime.Now.Year</a></li>
                    <li><a href="#" class="white"><i class="icon-location-pin white"></i> İstanbul, Türkiye</a></li>
                    <li><a href="#" class="white"><i class="icon-clock white"></i> Pzrt-Cts: 08.30-18.00</a></li>
                </ul>
            </div>
            <div class="links float-right d-flex align-items-center gap-3">
                <ul class="mb-0 d-flex gap-2">
                    <li><a href="#" class="white"><i class="fab fa-facebook"></i></a></li>
                    <li><a href="#" class="white"><i class="fab fa-twitter"></i></a></li>
                    <li><a href="#" class="white"><i class="fab fa-instagram"></i></a></li>
                    <li><a href="#" class="white"><i class="fab fa-linkedin"></i></a></li>
                </ul>

                @* ── DİL SEÇİCİ ── *@
                <div class="d-flex align-items-center gap-1">
                    <i class="fa fa-globe white" style="font-size:.8rem;opacity:.8;"></i>
                    <select id="headerLangSelect" onchange="doGoogleTranslate(this.value)"
                            style="background:rgba(255,255,255,0.15);border:1px solid rgba(255,255,255,0.3);color:#fff;border-radius:5px;padding:.15rem .5rem;font-size:.78rem;cursor:pointer;outline:none;">
                        <option value="tr">TR</option>
                        <option value="en">EN</option>
                        <option value="de">DE</option>
                        <option value="fr">FR</option>
                        <option value="es">ES</option>
                        <option value="it">IT</option>
                        <option value="ru">RU</option>
                        <option value="zh-CN">ZH</option>
                        <option value="ja">JA</option>
                        <option value="ko">KO</option>
                        <option value="pt">PT</option>
                        <option value="nl">NL</option>
                        <option value="pl">PL</option>
                        <option value="sv">SV</option>
                        <option value="ar">AR</option>
                        <option value="he">HE</option>
                        <option value="fa">FA</option>
                        <option value="hi">HI</option>
                        <option value="th">TH</option>
                        <option value="vi">VI</option>
                        <option value="id">ID</option>
                        <option value="az">AZ</option>
                        <option value="kk">KK</option>
                        <option value="uz">UZ</option>
                        <option value="uk">UK</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <div class="header_menu" id="header_menu">
        <nav class="navbar navbar-default">
            <div class="container">
                <div class="navbar-flex d-flex align-items-center justify-content-between w-100 pb-3 pt-3">
                    <div class="navbar-header">
                        <a class="navbar-brand" href="/Home/Index">
                            <img src="/travelin/images/logo.png" alt="logo">
                        </a>
                    </div>
                    <div class="navbar-collapse1 d-flex align-items-center" id="bs-example-navbar-collapse-1">
                        <ul class="nav navbar-nav" id="responsive-menu">
                            <li><a href="/Home/Index">Ana Sayfa</a></li>
                            <li><a href="/Tour/TourList">Tur Listesi</a></li>
                            <li><a href="/Tour/TourRoutes">Tur Rotaları</a></li>
                        </ul>
                    </div>
                    <div class="register-login d-flex align-items-center gap-3">
                        @if (User.Identity.IsAuthenticated)
                        {
                            @* Dinamik Panel Yönlendirmesi *@
                            string targetUrl = "/Customer/Dashboard";
                            if (User.IsInRole("Admin")) { targetUrl = "/AdminTour/TourList"; }
                            else if (User.IsInRole("Guide")) { targetUrl = "/Guide/MyTours"; }

                            @* KULLANICI ADI *@
                            <a href="@targetUrl" class="me-2 fw-bold text-uppercase d-flex align-items-center gap-1">
                                <i class="icon-user"></i> @User.Identity.Name
                            </a>

                            @* ÇIKIŞ BUTONU *@
                            <a href="/Login/Logout" class="me-2 text-danger" title="Çıkış Yap">
                                <i class="fa fa-sign-out-alt"></i>
                            </a>

                            @* REZERVASYON BUTONU *@
                            @* Eğer Admin ise NewReservation'a gitmesin diyorsan buraya if(User.IsInRole("Admin")) ekleyebilirsin *@
                            <a href="/Reservation/NewReservation" class="nir-btn white">Rezervasyon Yap</a>
                        }
                        else
                        {
                            @* GİRİŞ YAPMAMIŞ KULLANICI *@
                            <div class="d-flex align-items-center gap-2">
                                <a href="#" data-bs-toggle="modal" data-bs-target="#exampleModal" title="Kullanıcı Giriş">
                                    <i class="icon-user" style="font-size: 20px;"></i>
                                </a>
                                <a href="#" data-bs-toggle="modal" data-bs-target="#adminModal" title="Admin Giriş">
                                    <i class="fa fa-shield-alt text-danger" style="font-size: 20px;"></i>
                                </a>
                            </div>

                            <a href="javascript:void(0);" data-bs-toggle="modal" data-bs-target="#exampleModal" class="nir-btn white">Rezervasyon Yap</a>
                        }
                    </div>
                    <div id="slicknav-mobile"></div>
                </div>
            </div>
        </nav>
    </div>
</header>

@* Google Translate gizli widget *@
<div id="google_translate_element" style="display:none;"></div>

<style>
    .goog-te-banner-frame, .skiptranslate {
        display: none !important;
    }

    body {
        top: 0 !important;
    }

    #google_translate_element, .goog-te-gadget {
        display: none !important;
    }
</style>