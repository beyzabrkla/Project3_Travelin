<header class="main_header_area">
    <div class="header-content py-1 bg-theme">
        <div class="container d-flex align-items-center justify-content-between">
            <div class="links">
                <ul>
                    <li><a href="#" class="white"><i class="icon-calendar white"></i> @DateTime.Now.Year</a></li>
                    <li><a href="#" class="white"><i class="icon-location-pin white"></i>  İstanbul, Türkiye</a></li>
                    <li><a href="#" class="white"><i class="icon-clock white"></i> Pzrt-Cts: 08.30-18.00</a></li>
                </ul>
            </div>
            <div class="links float-right">
                <ul>
                    <li><a href="#" class="white"><i class="fab fa-facebook" aria-hidden="true"></i></a></li>
                    <li><a href="#" class="white"><i class="fab fa-twitter" aria-hidden="true"></i></a></li>
                    <li><a href="#" class="white"><i class="fab fa-instagram" aria-hidden="true"></i></a></li>
                    <li><a href="#" class="white"><i class="fab fa-linkedin " aria-hidden="true"></i></a></li>
                </ul>
            </div>
        </div>
    </div>
    <!-- Navigation Bar -->
    <div class="header_menu" id="header_menu">
        <nav class="navbar navbar-default">
            <div class="container">
                <div class="navbar-flex d-flex align-items-center justify-content-between w-100 pb-3 pt-3">
                    <!-- Brand and toggle get grouped for better mobile display -->
                    <div class="navbar-header">
                        <a class="navbar-brand" href="/Home/Index">
                            <img src="/travelin/images/logo.png" alt="image">
                        </a>
                    </div>
                    <!-- Collect the nav links, forms, and other content for toggling -->
                    <div class="navbar-collapse1 d-flex align-items-center" id="bs-example-navbar-collapse-1">
                        <ul class="nav navbar-nav" id="responsive-menu">

                            <li><a href="/Home/Index">Ana Sayfa</a></li>
                            <li><a href="/Tour/TourList">Tur Lİstesİ</a></li>
                            <li><a href="/Tour/TourRoutes">Tur Rotaları</a></li>
                            <li><a href="about.html">VİZESİZ Turlar</a></li>
                            <li><a href="about.html">Yurt İçİ Turları</a></li>


                            <li class="search-main"><a href="#search1" class="mt_search"><i class="fa fa-search"></i></a></li>
                        </ul>
                    </div><!-- /.navbar-collapse -->
                    <div class="register-login d-flex align-items-center">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <a href="/Customer/Dashboard" class="me-3">
                                <i class="icon-user"></i> @User.Identity.Name
                            </a>
                            <a href="/Login/Logout" class="me-3 text-danger">
                                <i class="fa fa-sign-out-alt"></i> Çıkış Yap
                            </a>
                        }
                        else
                        {
                            <a href="#" data-bs-toggle="modal" data-bs-target="#exampleModal" class="me-3">
                                <i class="icon-user"></i> Giriş Yap / Kayıt Ol
                            </a>
                        }

                        @if (User.Identity.IsAuthenticated)
                        {
                            <a href="/Reservation/NewReservation" class="nir-btn white">Rezervasyon Yap</a>
                        }
                        else
                        {
                            <a href="#" data-bs-toggle="modal" data-bs-target="#exampleModal" class="nir-btn white">Rezervasyon Yap</a>
                        }
                    </div>

                    <div id="slicknav-mobile"></div>
                </div>
            </div><!-- /.container-fluid -->
        </nav>
    </div>
    <!-- Navigation Bar Ends -->
</header>

