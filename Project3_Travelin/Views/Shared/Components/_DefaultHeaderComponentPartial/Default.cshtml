<header class="main_header_area">
    <div class="header-content py-1 bg-theme">
        <div class="container d-flex align-items-center justify-content-between">
            <div class="links">
                <ul>
                    <li><a href="#" class="white"><i class="icon-calendar white"></i> @DateTime.Now.Year</a></li>
                    <li><a href="#" class="white"><i class="icon-location-pin white"></i>  İstanbul, Türkiye</a></li>
                    <li><a href="#" class="white"><i class="icon-clock white"></i> Pzrt-Cts: 08.30-18.00</a></li>
                </ul>
            </div>
            <div class="links float-right d-flex align-items-center gap-3">
                <ul class="mb-0">
                    <li><a href="#" class="white"><i class="fab fa-facebook" aria-hidden="true"></i></a></li>
                    <li><a href="#" class="white"><i class="fab fa-twitter" aria-hidden="true"></i></a></li>
                    <li><a href="#" class="white"><i class="fab fa-instagram" aria-hidden="true"></i></a></li>
                    <li><a href="#" class="white"><i class="fab fa-linkedin" aria-hidden="true"></i></a></li>
                </ul>

                @* ── DİL SEÇİCİ (script component'te) ── *@
                <div class="d-flex align-items-center gap-1">
                    <i class="fa fa-globe white" style="font-size:.8rem;opacity:.8;"></i>
                    <select id="headerLangSelect"
                            onchange="doGoogleTranslate(this.value)"
                            style="background:rgba(255,255,255,0.15);border:1px solid rgba(255,255,255,0.3);color:#fff;border-radius:5px;padding:.15rem .5rem;font-size:.78rem;cursor:pointer;outline:none;">
                        <option value="tr" style="color:#000;background:#fff;">TR 🇹🇷</option>
                        <option value="en" style="color:#000;background:#fff;">EN 🇬🇧</option>
                        <option value="de" style="color:#000;background:#fff;">DE 🇩🇪</option>
                        <option value="fr" style="color:#000;background:#fff;">FR 🇫🇷</option>
                        <option value="es" style="color:#000;background:#fff;">ES 🇪🇸</option>
                        <option value="it" style="color:#000;background:#fff;">IT 🇮🇹</option>
                        <option value="ru" style="color:#000;background:#fff;">RU 🇷🇺</option>
                        <option value="zh-CN" style="color:#000;background:#fff;">ZH 🇨🇳</option>
                        <option value="ja" style="color:#000;background:#fff;">JA 🇯🇵</option>
                        <option value="ko" style="color:#000;background:#fff;">KO 🇰🇷</option>
                        <option value="pt" style="color:#000;background:#fff;">PT 🇵🇹</option>
                        <option value="nl" style="color:#000;background:#fff;">NL 🇳🇱</option>
                        <option value="pl" style="color:#000;background:#fff;">PL 🇵🇱</option>
                        <option value="sv" style="color:#000;background:#fff;">SV 🇸🇪</option>
                        <option value="da" style="color:#000;background:#fff;">DA 🇩🇰</option>
                        <option value="fi" style="color:#000;background:#fff;">FI 🇫🇮</option>
                        <option value="no" style="color:#000;background:#fff;">NO 🇳🇴</option>
                        <option value="cs" style="color:#000;background:#fff;">CS 🇨🇿</option>
                        <option value="hu" style="color:#000;background:#fff;">HU 🇭🇺</option>
                        <option value="ro" style="color:#000;background:#fff;">RO 🇷🇴</option>
                        <option value="bg" style="color:#000;background:#fff;">BG 🇧🇬</option>
                        <option value="uk" style="color:#000;background:#fff;">UK 🇺🇦</option>
                        <option value="el" style="color:#000;background:#fff;">EL 🇬🇷</option>
                        <option value="he" style="color:#000;background:#fff;">HE 🇮🇱</option>
                        <option value="fa" style="color:#000;background:#fff;">FA 🇮🇷</option>
                        <option value="hi" style="color:#000;background:#fff;">HI 🇮🇳</option>
                        <option value="th" style="color:#000;background:#fff;">TH 🇹🇭</option>
                        <option value="vi" style="color:#000;background:#fff;">VI 🇻🇳</option>
                        <option value="id" style="color:#000;background:#fff;">ID 🇮🇩</option>
                        <option value="ms" style="color:#000;background:#fff;">MS 🇲🇾</option>
                        <option value="az" style="color:#000;background:#fff;">AZ 🇦🇿</option>
                        <option value="kk" style="color:#000;background:#fff;">KK 🇰🇿</option>
                        <option value="uz" style="color:#000;background:#fff;">UZ 🇺🇿</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <div class="header_menu" id="header_menu">
        <nav class="navbar navbar-default">
            <div class="container">
                <div class="navbar-flex d-flex align-items-center justify-content-between w-100 pb-3 pt-3">
                    <div class="navbar-header">
                        <a class="navbar-brand" href="/Home/Index">
                            <img src="/travelin/images/logo.png" alt="image">
                        </a>
                    </div>
                    <div class="navbar-collapse1 d-flex align-items-center" id="bs-example-navbar-collapse-1">
                        <ul class="nav navbar-nav" id="responsive-menu">
                            <li><a href="/Home/Index">Ana Sayfa</a></li>
                            <li><a href="/Tour/TourList">Tur Lİstesİ</a></li>
                            <li><a href="/Tour/TourRoutes">Tur Rotaları</a></li>
                        </ul>
                    </div>
                    <div class="register-login d-flex align-items-center gap-3">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <a href="@(User.IsInRole("Guide") ? "/Guide/MyTours" : "/Customer/Dashboard")" class="me-2">
                                <i class="icon-user"></i> @User.Identity.Name
                            </a>
                            <a href="/Login/Logout" class="me-2 text-danger">
                                <i class="fa fa-sign-out-alt"></i> Çıkış Yap
                            </a>
                        }
                        else
                        {
                            <a href="#" data-bs-toggle="modal" data-bs-target="#exampleModal" class="me-3" title="Kullanıcı Giriş">
                                <i class="icon-user" style="font-size: 20px;"></i>
                            </a>
                            <a href="#" data-bs-toggle="modal" data-bs-target="#adminModal" class="me-3" title="Admin Giriş">
                                <i class="fa fa-shield-alt text-danger" style="font-size: 20px;"></i>
                            </a>
                        }
                        @if (User.Identity.IsAuthenticated)
                        {
                            <a href="/Reservation/NewReservation" class="nir-btn white">Rezervasyon Yap</a>
                        }
                        else
                        {
                            <a href="#" data-bs-toggle="modal" data-bs-target="#exampleModal" class="nir-btn white">Rezervasyon Yap</a>
                        }
                    </div>
                    <div id="slicknav-mobile"></div>
                </div>
            </div>
        </nav>
    </div>
</header>

@* Google Translate gizli widget - script component'teki init fonksiyonu bunu kullanır *@
<div id="google_translate_element" style="display:none;"></div>

<style>
    .goog-te-banner-frame, .skiptranslate {
        display: none !important;
    }

    body {
        top: 0 !important;
    }

    #google_translate_element, .goog-te-gadget {
        display: none !important;
    }
</style>
