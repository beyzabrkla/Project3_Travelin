<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="shortcut icon" type="image/x-icon" href="/travelin/images/favicon.png">
    <title>@ViewData["Title"] — Admin</title>
    <link href="/css/Admin.css" rel="stylesheet" type="text/css">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

    <!-- SIDEBAR -->
    <aside class="sidebar" id="sidebar">
        <a href="#" class="sidebar-brand">
            <div class="brand-icon"><i class="bi bi-compass"></i></div>
            <div>
                <div class="brand-name">TourAdmin</div>
                <span class="brand-sub">Yönetim Paneli</span>
            </div>
        </a>

        <!-- TURLAR -->
        <div class="sidebar-section">
            <div class="sidebar-section-label">Turlar</div>
            <a href="/AdminTour/TourList" class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminTour" ? "active" : "")">
                <i class="bi bi-map"></i> Tüm Turlar
            </a>
            <a href="/AdminTour/TourList?status=active" class="nav-item-link">
                <i class="bi bi-check-circle text-success"></i> Aktif Turlar
            </a>
            <a href="/AdminTour/TourList?status=draft" class="nav-item-link">
                <i class="bi bi-pencil-square text-warning"></i> Taslak Turlar
            </a>
            <a href="/AdminTour/TourList?status=passive" class="nav-item-link">
                <i class="bi bi-x-circle text-danger"></i> Pasif Turlar
            </a>
            <a href="/AdminTour/CreateTour" class="nav-item-link">
                <i class="bi bi-plus-circle"></i> Yeni Tur Ekle
            </a>
        </div>

        <!-- REZERVASYONLAR -->
        <div class="sidebar-section">
            <div class="sidebar-section-label">Rezervasyonlar</div>
            <a href="/AdminReservation/ReservationList" class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminReservation" ? "active" : "")">
                <i class="bi bi-calendar2-check"></i> Tüm Rezervasyonlar
            </a>
            <a href="/AdminReservation/ReservationList?status=pending" class="nav-item-link">
                <i class="bi bi-hourglass-split text-warning"></i> Onay Bekleyenler
            </a>
            <a href="/AdminReservation/ReservationList?status=approved" class="nav-item-link">
                <i class="bi bi-check2-circle text-success"></i> Onaylananlar
            </a>
            <a href="/AdminReservation/ReservationList?status=rejected" class="nav-item-link">
                <i class="bi bi-x-circle text-danger"></i> Reddedilenler
            </a>
        </div>

        <!-- YÖNETİM -->
        <div class="sidebar-section">
            <div class="sidebar-section-label">Yönetim</div>
            <a href="/AdminGuide/GuideList" class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminGuide" ? "active" : "")">
                <i class="bi bi-people"></i> Rehberler
            </a>
            <a href="/AdminCategory/CategoryList" class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminCategory" ? "active" : "")">
                <i class="bi bi-tags"></i> Kategoriler
            </a>
            <a href="/AdminReview/ReviewList" class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminReview" ? "active" : "")">
                <i class="bi bi-star"></i> Yorumlar
            </a>
            <a href="/AdminUser/UserList" class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminUser" ? "active" : "")">
                <i class="bi bi-person-badge"></i> Müşteriler
            </a>
        </div>

        <!-- RAPORLAR -->
        <div class="sidebar-section">
            <div class="sidebar-section-label">Raporlar</div>
            <a href="/AdminReport/TourCustomers" class="nav-item-link">
                <i class="bi bi-people-fill"></i> Tur Müşteri Listeleri
            </a>
            <a href="/AdminReport/Dashboard" class="nav-item-link">
                <i class="bi bi-bar-chart-line"></i> Genel Rapor
            </a>
        </div>

        <div class="sidebar-footer">
            <a href="#" class="nav-item-link">
                <i class="bi bi-box-arrow-left"></i> Çıkış Yap
            </a>
        </div>
    </aside>

    <!-- TOPBAR -->
    <header class="topbar">
        <button class="hamburger" onclick="toggleSidebar()" aria-label="Menüyü aç/kapat">
            <i class="bi bi-list"></i>
        </button>
        <span class="topbar-title">@ViewData["Title"]</span>
        <div class="topbar-spacer"></div>
        <div class="topbar-actions">
            <button class="topbar-icon-btn" aria-label="Bildirimler">
                <i class="bi bi-bell"></i>
                <span class="notif-dot"></span>
            </button>
            <button class="topbar-icon-btn" aria-label="Mesajlar">
                <i class="bi bi-chat-dots"></i>
            </button>
            <div class="dropdown">
                <div class="admin-profile" data-bs-toggle="dropdown" aria-expanded="false">
                    <div class="admin-avatar">A</div>
                    <div>
                        <div class="admin-name">Admin Kullanıcı</div>
                        <span class="admin-role">Süper Admin</span>
                    </div>
                    <i class="bi bi-chevron-down ms-1" style="font-size:.7rem;color:#718096"></i>
                </div>
                <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-1">
                    <li><a class="dropdown-item" href="#"><i class="bi bi-person me-2"></i>Profilim</a></li>
                    <li><a class="dropdown-item" href="#"><i class="bi bi-gear me-2"></i>Ayarlar</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item text-danger" href="#"><i class="bi bi-box-arrow-left me-2"></i>Çıkış Yap</a></li>
                </ul>
            </div>
        </div>
    </header>

    <!-- MAIN -->
    <main class="main-wrapper">
        @RenderBody()
    </main>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('open');
            document.getElementById('sidebarOverlay').classList.toggle('show');
        }

        // Aktif menü linkini vurgula
        document.addEventListener('DOMContentLoaded', function () {
            const currentPath = window.location.pathname + window.location.search;
            document.querySelectorAll('.nav-item-link').forEach(function (link) {
                const href = link.getAttribute('href');
                if (href && currentPath === href) {
                    link.classList.add('active');
                }
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
