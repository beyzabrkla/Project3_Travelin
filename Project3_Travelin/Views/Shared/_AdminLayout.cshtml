@{
    var statusQuery = Context.Request.Query["status"].ToString().ToLower();
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="shortcut icon" type="image/x-icon" href="/travelin/images/favicon.png">
    <title>@ViewData["Title"] — Admin</title>
    <link href="/css/Admin.css" rel="stylesheet" type="text/css">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        /* Google Translate banner'ını gizle */
        .goog-te-banner-frame, .skiptranslate {
            display: none !important;
        }

        body {
            top: 0 !important;
        }

        #google_translate_element {
            display: none !important;
        }

        .goog-te-gadget {
            display: none !important;
        }

        /* Dil seçici dropdown */
        .lang-select {
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.15);
            color: #e2e8f0;
            border-radius: 8px;
            padding: .3rem .6rem;
            font-size: .78rem;
            cursor: pointer;
            outline: none;
            transition: all .2s;
        }

            .lang-select:hover {
                background: rgba(255,255,255,0.15);
            }

            .lang-select option {
                background: #2d3748;
                color: #e2e8f0;
            }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

    <!-- SIDEBAR -->
    <aside class="sidebar" id="sidebar">
        <a href="#" class="sidebar-brand">
            <div class="brand-icon"><i class="bi bi-compass"></i></div>
            <div>
                <div class="brand-name">TourAdmin</div>
                <span class="brand-sub">Yönetim Paneli</span>
            </div>
        </a>

        <!-- TURLAR -->
        <div class="sidebar-section">
            <div class="sidebar-section-label">Turlar</div>
            <a href="/AdminTour/TourList" class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminTour" ? "active" : "")">
                <i class="bi bi-map"></i> Tüm Turlar
            </a>
            <a href="/AdminTour/TourList?status=active" class="nav-item-link">
                <i class="bi bi-check-circle text-success"></i> Aktif Turlar
            </a>
            <a href="/AdminTour/TourList?status=draft" class="nav-item-link">
                <i class="bi bi-pencil-square text-warning"></i> Taslak Turlar
            </a>
            <a href="/AdminTour/TourList?status=passive" class="nav-item-link">
                <i class="bi bi-x-circle text-danger"></i> Pasif Turlar
            </a>
            <a href="/AdminTour/CreateTour" class="nav-item-link">
                <i class="bi bi-plus-circle"></i> Yeni Tur Ekle
            </a>
        </div>

        <!-- REZERVASYONLAR -->
        <div class="sidebar-section">
            <div class="sidebar-section-label">Rezervasyonlar</div>
            <a href="/AdminReservation/ReservationList"
               class="nav-item-link @(string.IsNullOrEmpty(statusQuery) ? "active" : "")">
                <i class="bi bi-calendar2-check"></i> Tüm Rezervasyonlar
            </a>
            <a href="/AdminReservation/ReservationList?status=pending"
               class="nav-item-link @(statusQuery == "pending" ? "active" : "")">
                <i class="bi bi-hourglass-split text-warning"></i> Onay Bekleyenler
            </a>
            <a href="/AdminReservation/ReservationList?status=approved"
               class="nav-item-link @(statusQuery == "approved" ? "active" : "")">
                <i class="bi bi-check2-circle text-success"></i> Onaylananlar
            </a>
            <a href="/AdminReservation/ReservationList?status=rejected"
               class="nav-item-link @(statusQuery == "rejected" ? "active" : "")">
                <i class="bi bi-x-circle text-danger"></i> Reddedilenler
            </a>
        </div>

        <!-- YÖNETİM -->
        <div class="sidebar-section">
            <div class="sidebar-section-label">Yönetim</div>
            <a href="/AdminUser/GuideList" class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminGuide" ? "active" : "")">
                <i class="bi bi-people"></i> Rehberler
            </a>
            <a href="/AdminReview/ReviewList" class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminReview" ? "active" : "")">
                <i class="bi bi-star"></i> Tüm Yorumlar
            </a>
            <a href="/AdminUser/UserList" class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminUser" ? "active" : "")">
                <i class="bi bi-person-badge"></i> Kullanıcılar
            </a>
        </div>

        <div class="sidebar-footer">
            <a href="/Login/Logout" class="nav-item-link">
                <i class="bi bi-box-arrow-left"></i> Çıkış Yap
            </a>
        </div>
    </aside>

    <!-- TOPBAR -->
    <header class="topbar">
        <button class="hamburger" onclick="toggleSidebar()">
            <i class="bi bi-list"></i>
        </button>
        <span class="topbar-title">@ViewData["Title"]</span>
        <div class="topbar-spacer"></div>
        <div class="topbar-actions d-flex align-items-center gap-3">

            <!-- 🌐 DİL SEÇİCİ -->
            <div class="d-flex align-items-center gap-1">
                <i class="bi bi-translate" style="color:#a0aec0;font-size:.85rem;"></i>
                <select id="adminLangSelect" class="lang-select" onchange="doGoogleTranslate(this.value)">
                    <option value="tr">TR</option>
                    <option value="en">EN</option>
                    <option value="de">DE</option>
                    <option value="fr">FR</option>
                    <option value="es">ES</option>
                    <option value="it">IT</option>
                    <option value="ru">RU</option>
                    <option value="zh-CN">ZH</option>
                    <option value="ja">JA</option>
                    <option value="ko">KO</option>
                    <option value="pt">PT</option>
                    <option value="nl">NL</option>
                    <option value="pl">PL</option>
                    <option value="sv">SV</option>
                    <option value="ar">AR</option>
                    <option value="he">HE</option>
                    <option value="fa">FA</option>
                    <option value="hi">HI</option>
                    <option value="th">TH</option>
                    <option value="vi">VI</option>
                    <option value="id">ID</option>
                    <option value="az">AZ</option>
                    <option value="kk">KK</option>
                    <option value="uz">UZ</option>
                    <option value="uk">UK</option>
                </select>
            </div>

            <div class="dropdown">
                <div class="admin-profile" data-bs-toggle="dropdown" aria-expanded="false">
                    <div class="admin-avatar">A</div>
                    <div>
                        <div class="admin-name">Admin Kullanıcı</div>
                        <span class="admin-role">Süper Admin</span>
                    </div>
                    <i class="bi bi-chevron-down ms-1" style="font-size:.7rem;color:#718096"></i>
                </div>
            </div>
        </div>
    </header>

    <!-- MAIN -->
    <main class="main-wrapper">
        @RenderBody()
    </main>

    <!-- Google Translate gizli widget -->
    <div id="google_translate_element" style="display:none;"></div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('open');
            document.getElementById('sidebarOverlay').classList.toggle('show');
        }

        document.addEventListener('DOMContentLoaded', function () {
            const currentPath = window.location.pathname + window.location.search;
            document.querySelectorAll('.nav-item-link').forEach(link => link.classList.remove('active'));
            document.querySelectorAll('.nav-item-link').forEach(function (link) {
                const href = link.getAttribute('href');
                if (href && currentPath === href) link.classList.add('active');
                else if (href && window.location.pathname === href && !window.location.search) link.classList.add('active');
            });

            // Aktif dili dropdown'da göster
            var match = document.cookie.match(/googtrans=\/tr\/([a-zA-Z-]+)/);
            if (match && match[1]) {
                var sel = document.getElementById('adminLangSelect');
                for (var i = 0; i < sel.options.length; i++) {
                    if (sel.options[i].value === match[1]) { sel.selectedIndex = i; break; }
                }
            }
        });

        // ── GOOGLE TRANSLATE ──────────────────────────
        function googleTranslateElementInit() {
            new google.translate.TranslateElement(
                { pageLanguage: 'tr', autoDisplay: false },
                'google_translate_element'
            );
        }

        function doGoogleTranslate(lang) {
            if (lang === 'tr') {
                var d = new Date();
                d.setTime(d.getTime() + (-1 * 24 * 60 * 60 * 1000));
                document.cookie = "googtrans=; expires=" + d.toGMTString() + "; path=/";
                document.cookie = "googtrans=; expires=" + d.toGMTString() + "; domain=" + window.location.hostname;
                window.location.reload();
                return;
            }
            var val = '/tr/' + lang;
            document.cookie = "googtrans=" + val + "; path=/";
            document.cookie = "googtrans=" + val + "; domain=" + window.location.hostname;
            window.location.reload();
        }
    </script>

    <script src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
