<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="shortcut icon" type="image/x-icon" href="/travelin/images/favicon.png">
    <title>@ViewData["Title"] — Müşteri Paneli</title>
    <link href="/css/Admin.css" rel="stylesheet" type="text/css">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        :root {
            --sidebar-bg: #1a1c23;
            --theme-pink: #d946ef;
        }

        .sidebar-brand {
            display: flex !important;
            align-items: center !important;
            padding: 1.5rem 1.25rem !important;
            text-decoration: none !important;
        }

        .nav-item-link.active {
            background-color: rgba(217,70,239,0.1) !important;
            color: var(--theme-pink) !important;
            border-left: 3px solid var(--theme-pink) !important;
            font-weight: 700 !important;
        }

            .nav-item-link.active i {
                color: var(--theme-pink) !important;
            }

        .brand-sub {
            color: var(--theme-pink) !important;
            font-size: 0.9rem !important;
            font-weight: 600 !important;
            display: block !important;
            margin-top: 2px !important;
        }

        .brand-name {
            font-size: 1.25rem !important;
            font-weight: 800 !important;
            color: #fff !important;
            line-height: 1.1 !important;
        }

        .nav-item-link {
            color: rgba(255,255,255,0.6) !important;
            transition: all 0.3s ease;
        }

            .nav-item-link:hover {
                color: var(--theme-pink) !important;
                background-color: rgba(217,70,239,0.05) !important;
            }

        .guide-nav-section .sidebar-section-label {
            color: #a78bfa !important;
        }
        /* Google Translate banner gizle */
        .goog-te-banner-frame, .skiptranslate {
            display: none !important;
        }

        body {
            top: 0 !important;
        }

        #google_translate_element, .goog-te-gadget {
            display: none !important;
        }
        /* Dil seçici */
        .lang-select {
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.15);
            color: #e2e8f0;
            border-radius: 8px;
            padding: .3rem .6rem;
            font-size: .78rem;
            cursor: pointer;
            outline: none;
            transition: all .2s;
        }

            .lang-select:hover {
                background: rgba(255,255,255,0.15);
            }

            .lang-select option {
                background: #2d3748;
                color: #e2e8f0;
            }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

    <aside class="sidebar" id="sidebar">
        <a href="#" class="sidebar-brand">
            <div class="brand-icon"><i class="bi bi-person-workspace"></i></div>
            <div>
                <span class="brand-sub">
                    @if (User.IsInRole("Admin"))
                    {
                        <span>Admin Paneli</span>
                    }
                    else if (User.IsInRole("Guide"))
                    {

                        <span>Rehber Alanı</span>
                    }
                    else
                    {

                        <span>Müşteri Alanı</span>
                    }
                </span>
            </div>
        </a>

        @* MÜŞTERİ MENÜSÜ (Admin veya Guide olmayan herkes görür) *@
        @if (!User.IsInRole("Admin") && !User.IsInRole("Guide"))
        {
            <div class="sidebar-section">
                <div class="sidebar-section-label">Menü</div>
                <a href="/Customer/Dashboard" class="nav-item-link"><i class="bi bi-speedometer2"></i> Dashboard</a>
            </div>
            <div class="sidebar-section">
                <div class="sidebar-section-label">Gezilerim</div>
                <a href="/Reservation/MyReservations" class="nav-item-link"><i class="bi bi-calendar-event"></i> Rezervasyonlarım</a>
                <a href="/Reservation/NewReservation" class="nav-item-link"><i class="bi bi-plus-circle"></i> Yeni Rezervasyon Yap</a>
            </div>
            <div class="sidebar-section">
                <div class="sidebar-section-label">Hesabım</div>
                <a href="/Customer/Profile" class="nav-item-link"><i class="bi bi-person-gear"></i> Profil Ayarları</a>
            </div>
        }

        @* REHBER MENÜSÜ *@
        @if (User.IsInRole("Guide"))
        {
            <div class="sidebar-section guide-nav-section">
                <div class="sidebar-section-label">Rehberlik</div>
                <a href="/Guide/MyTours" class="nav-item-link"><i class="bi bi-map"></i> Turlarımı Yönet</a>
            </div>
            <div class="sidebar-section">
                <div class="sidebar-section-label">Hesabım</div>
                <a href="/Customer/Profile" class="nav-item-link"><i class="bi bi-person-gear"></i> Profil Ayarları</a>
            </div>
        }

        <div class="sidebar-footer">
            <a href="/Login/Logout" class="nav-item-link text-danger"><i class="bi bi-box-arrow-left"></i> Çıkış Yap</a>
        </div>
    </aside>
    <header class="topbar">
        <button class="hamburger" onclick="toggleSidebar()"><i class="bi bi-list"></i></button>
        <span class="topbar-title">@ViewData["Title"]</span>
        <div class="topbar-spacer"></div>
        <div class="topbar-actions d-flex align-items-center gap-3">

            <!-- 🌐 DİL SEÇİCİ -->
            <div class="d-flex align-items-center gap-1">
                <i class="bi bi-translate" style="color:#a0aec0;font-size:.85rem;"></i>
                <select id="customerLangSelect" class="lang-select" onchange="doGoogleTranslate(this.value)">
                    <option value="tr">TR</option>
                    <option value="en">EN</option>
                    <option value="de">DE</option>
                    <option value="fr">FR</option>
                    <option value="es">ES</option>
                    <option value="it">IT</option>
                    <option value="ru">RU</option>
                    <option value="zh-CN">ZH</option>
                    <option value="ja">JA</option>
                    <option value="ko">KO</option>
                    <option value="pt">PT</option>
                    <option value="nl">NL</option>
                    <option value="pl">PL</option>
                    <option value="sv">SV</option>
                    <option value="ar">AR</option>
                    <option value="he">HE</option>
                    <option value="fa">FA</option>
                    <option value="hi">HI</option>
                    <option value="th">TH</option>
                    <option value="vi">VI</option>
                    <option value="id">ID</option>
                    <option value="az">AZ</option>
                    <option value="kk">KK</option>
                    <option value="uz">UZ</option>
                    <option value="uk">UK</option>
                </select>
            </div>

            <div class="dropdown">
                <div class="admin-profile" data-bs-toggle="dropdown" aria-expanded="false">
                    <div class="admin-avatar" style="background:#6366f1">@User.Identity.Name.Substring(0, 1).ToUpper()</div>
                    <div>
                        <div class="admin-name">@User.Identity.Name</div>
                        <span class="admin-role">@(User.IsInRole("Guide") ? "Tur Rehberi" : "Gezgin Üye")</span>
                    </div>
                    <i class="bi bi-chevron-down ms-1" style="font-size:.7rem;color:#718096"></i>
                </div>
                <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-1">
                    <li><a class="dropdown-item" href="/Customer/Profile"><i class="bi bi-person me-2"></i>Profilim</a></li>
                    @if (User.IsInRole("Guide"))
                    {
                        <li><a class="dropdown-item" href="/Guide/MyTours"><i class="bi bi-map me-2"></i>Turlarım</a></li>
                    }
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item text-danger" href="/Login/Logout"><i class="bi bi-box-arrow-left me-2"></i>Çıkış Yap</a></li>
                </ul>
            </div>
        </div>
    </header>

    <main class="main-wrapper">
        <div class="container-fluid p-4">@RenderBody()</div>
    </main>

    <div id="google_translate_element" style="display:none;"></div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('open');
            document.getElementById('sidebarOverlay').classList.toggle('show');
        }
        document.addEventListener('DOMContentLoaded', function () {
            const currentPath = window.location.pathname;
            document.querySelectorAll('.nav-item-link').forEach(function (link) {
                if (link.getAttribute('href') === currentPath) link.classList.add('active');
            });
            // Aktif dili göster
            var match = document.cookie.match(/googtrans=\/tr\/([a-zA-Z-]+)/);
            if (match && match[1]) {
                var sel = document.getElementById('customerLangSelect');
                for (var i = 0; i < sel.options.length; i++) {
                    if (sel.options[i].value === match[1]) { sel.selectedIndex = i; break; }
                }
            }
        });
        function googleTranslateElementInit() {
            new google.translate.TranslateElement({ pageLanguage: 'tr', autoDisplay: false }, 'google_translate_element');
        }
        function doGoogleTranslate(lang) {
            if (lang === 'tr') {
                var d = new Date();
                d.setTime(d.getTime() + (-1 * 24 * 60 * 60 * 1000));
                document.cookie = "googtrans=; expires=" + d.toGMTString() + "; path=/";
                document.cookie = "googtrans=; expires=" + d.toGMTString() + "; domain=" + window.location.hostname;
                window.location.reload();
                return;
            }
            var val = '/tr/' + lang;
            document.cookie = "googtrans=" + val + "; path=/";
            document.cookie = "googtrans=" + val + "; domain=" + window.location.hostname;
            window.location.reload();
        }
    </script>
    <script src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
