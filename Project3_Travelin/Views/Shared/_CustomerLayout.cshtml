<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="shortcut icon" type="image/x-icon" href="/travelin/images/favicon.png">
    <title>@ViewData["Title"] — Müşteri Paneli</title>
    <link href="/css/Admin.css" rel="stylesheet" type="text/css">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        :root {
            --sidebar-bg: #1a1c23;
            --theme-pink: #d946ef;
        }

        .sidebar-brand {
            display: flex !important;
            align-items: center !important;
            padding: 1.5rem 1.25rem !important;
            text-decoration: none !important;
        }

        .nav-item-link.active {
            background-color: rgba(217, 70, 239, 0.1) !important;
            color: var(--theme-pink) !important;
            border-left: 3px solid var(--theme-pink) !important;
            font-weight: 700 !important;
        }

            .nav-item-link.active i {
                color: var(--theme-pink) !important;
            }

        .brand-sub {
            color: var(--theme-pink) !important;
            font-size: 0.9rem !important;
            font-weight: 600 !important;
            display: block !important;
            margin-top: 2px !important;
            opacity: 1 !important;
        }

        .brand-name {
            font-size: 1.25rem !important;
            font-weight: 800 !important;
            color: #ffffff !important;
            line-height: 1.1 !important;
        }

        .nav-item-link {
            color: rgba(255, 255, 255, 0.6) !important;
            transition: all 0.3s ease;
        }

            .nav-item-link:hover {
                color: var(--theme-pink) !important;
                background-color: rgba(217, 70, 239, 0.05) !important;
            }

        /* Rehber bölümü özel vurgu */
        .guide-nav-section .sidebar-section-label {
            color: #a78bfa !important;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

    <aside class="sidebar" id="sidebar">
        <a href="#" class="sidebar-brand">
            <div class="brand-icon"><i class="bi bi-person-workspace"></i></div>
            <div>
                <span class="brand-sub">@(User.IsInRole("Guide") ? "Rehber Alanı" : "Müşteri Alanı")</span>
            </div>
        </a>

        @* --- MÜŞTERİ (CUSTOMER) PANELİ --- *@
        @if (User.IsInRole("Customer"))
        {
            <div class="sidebar-section">
                <div class="sidebar-section-label">Menü</div>
                <a href="/Customer/Dashboard" class="nav-item-link">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>
            </div>

            <div class="sidebar-section">
                <div class="sidebar-section-label">Gezilerim</div>
                <a href="/Reservation/MyReservations" class="nav-item-link">
                    <i class="bi bi-calendar-event"></i> Rezervasyonlarım
                </a>
                <a href="/Reservation/NewReservation" class="nav-item-link">
                    <i class="bi bi-plus-circle"></i> Yeni Rezervasyon Yap
                </a>
            </div>

            <div class="sidebar-section">
                <div class="sidebar-section-label">Hesabım</div>
                <a href="/Customer/MyReviews" class="nav-item-link">
                    <i class="bi bi-chat-left-text"></i> Yorumlarım
                </a>
                <a href="/Customer/Profile" class="nav-item-link">
                    <i class="bi bi-person-gear"></i> Profil Ayarları
                </a>
            </div>
        }

        @* --- REHBER (GUIDE) PANELİ --- *@
        @if (User.IsInRole("Guide"))
        {
            <div class="sidebar-section">
                <div class="sidebar-section-label">Hesabım</div>
                <a href="/Customer/Profile" class="nav-item-link">
                    <i class="bi bi-person-gear"></i> Profil Ayarları
                </a>
            </div>

            <div class="sidebar-section guide-nav-section">
                <div class="sidebar-section-label">Rehberlik</div>
                <a href="/Guide/MyTours" class="nav-item-link">
                    <i class="bi bi-map"></i> Turlarımı Yönet
                </a>
            </div>
        }

        <div class="sidebar-footer">
            <a href="/Login/Logout" class="nav-item-link text-danger">
                <i class="bi bi-box-arrow-left"></i> Çıkış Yap
            </a>
        </div>
    </aside>
    <main class="main-wrapper">
        <div class="container-fluid p-4">
            @RenderBody()
        </div>
    </main>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('open');
            document.getElementById('sidebarOverlay').classList.toggle('show');
        }

        document.addEventListener('DOMContentLoaded', function () {
            const currentPath = window.location.pathname;
            document.querySelectorAll('.nav-item-link').forEach(function (link) {
                if (link.getAttribute('href') === currentPath) {
                    link.classList.add('active');
                }
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
