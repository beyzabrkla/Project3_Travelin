@model CreateReservationDTO
@{
    ViewData["Title"] = "Yeni Rezervasyon";
    Layout = "~/Views/Shared/_CustomerLayout.cshtml";
}

<form method="post" id="resForm">
    @Html.AntiForgeryToken()
    @* Sadece TourTitle hidden kalsın, TourId'yi aşağıda select ile seçeceğiz *@
    <input type="hidden" asp-for="TourTitle" id="hiddenTourTitle" value="@ViewBag.TourTitle" />

    <div class="row g-4">
        <div class="col-lg-8">
            @* TUR SEÇİM ALANI (YENİ EKLENDİ) *@
            <div class="form-section p-4 bg-white mb-4 shadow-sm" style="border-radius: 16px; border: 2px solid #6366f1;">
                <div class="section-header d-flex align-items-center gap-3 mb-4">
                    <div class="section-icon" style="background: rgba(99, 102, 241, 0.1); color: #6366f1; padding: 10px; border-radius: 12px;">
                        <i class="bi bi-map fs-4"></i>
                    </div>
                    <div>
                        <h5 class="mb-0 fw-bold">Gidilecek Turu Seçin</h5>
                        <p class="text-muted small mb-0">Listeden rezervasyon yapmak istediğiniz turu seçin.</p>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-12">
                        <label class="field-label fw-bold small text-uppercase" style="color:#718096;">Tur Listesi</label>
                        <select asp-for="TourId" asp-items="ViewBag.TourList" class="form-select form-select-lg" id="tourSelect" required style="border-radius: 12px; border: 1px solid #edf2f7;">
                            <option value="">--- Lütfen Tur Seçiniz ---</option>
                        </select>
                    </div>
                </div>
            </div>

            @* İLETİŞİM BİLGİLERİ (SENİN TASARIMIN) *@
            <div class="form-section p-4 bg-white mb-4 shadow-sm" style="border-radius: 16px; border: 1px solid #edf2f7;">
                <div class="section-header d-flex align-items-center gap-3 mb-4">
                    <div class="section-icon" style="background: rgba(217, 70, 239, 0.1); color: #d946ef; padding: 10px; border-radius: 12px;">
                        <i class="bi bi-person-badge fs-4"></i>
                    </div>
                    <div>
                        <h5 class="mb-0 fw-bold">İletişim Bilgileri</h5>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12 mb-3">
                        <label class="field-label fw-bold small text-uppercase" style="color:#718096;">Ad Soyad</label>
                        <input asp-for="CustomerName" class="form-control" placeholder="Adınızı ve soyadınızı girin" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="field-label fw-bold small text-uppercase" style="color:#718096;">E-Posta</label>
                        <input asp-for="CustomerEmail" type="email" class="form-control" placeholder="ornek@mail.com" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="field-label fw-bold small text-uppercase" style="color:#718096;">Telefon</label>
                        <input asp-for="CustomerPhone" type="tel" class="form-control" placeholder="05XX XXX XX XX" required />
                    </div>
                </div>
            </div>

            @* DETAYLAR (SENİN TASARIMIN) *@
            <div class="form-section p-4 bg-white shadow-sm" style="border-radius: 16px; border: 1px solid #edf2f7;">
                <div class="section-header d-flex align-items-center gap-3 mb-4">
                    <div class="section-icon" style="background: rgba(99, 102, 241, 0.1); color: #6366f1; padding: 10px; border-radius: 12px;">
                        <i class="bi bi-calendar-check fs-4"></i>
                    </div>
                    <div>
                        <h5 class="mb-0 fw-bold">Rezervasyon Detayları</h5>
                    </div>
                </div>
                <div class="mb-4">
                    <label class="form-label fw-bold small text-uppercase" style="color:#718096;">Katılımcı Sayısı</label>
                    <div class="d-flex align-items-center gap-3">
                        <div class="stepper d-flex align-items-center border rounded-3 overflow-hidden" style="width: 140px; height: 45px;">
                            <button type="button" class="btn btn-light rounded-0" onclick="changeCount(-1)">-</button>
                            <input asp-for="PersonCount" type="number" class="form-control border-0 text-center fw-bold" id="pCount" readonly />
                            <button type="button" class="btn btn-light rounded-0" onclick="changeCount(1)">+</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* SAĞ TARAFTAKİ ÖZET PANELİ *@
        <div class="col-lg-4">
            <div class="sidebar-sticky" style="position: sticky; top: 20px;">
                <div class="summary-card p-4 text-white shadow-lg" style="background: linear-gradient(135deg, #d946ef 0%, #9333ea 100%); border-radius: 24px;">
                    <h6 class="text-uppercase small fw-bold opacity-75 mb-4"><i class="bi bi-receipt me-2"></i>Tur Özeti</h6>

                    <div class="mb-3">
                        <label class="small opacity-75 d-block">Seçili Tur</label>
                        <span class="fs-6 fw-bold" id="sumTourTitle">Lütfen tur seçiniz</span>
                    </div>

                    <div class="mb-3">
                        <label class="small opacity-75 d-block">Toplam Katılımcı</label>
                        <span class="fs-5 fw-bold" id="sumPersonCount">1 Kişi</span>
                    </div>

                    <div class="mt-4 pt-3 border-top border-white border-opacity-25">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small">Durum</span>
                            <span class="badge bg-white text-dark rounded-pill">Onay Bekliyor</span>
                        </div>
                    </div>
                </div>

                <div class="d-grid gap-2 mt-4">
                    <button type="submit" class="btn btn-lg text-white py-3" style="background: #1a1c23; border-radius: 16px; font-weight: 700; border:none; transition: 0.3s;">
                        <i class="bi bi-send-fill me-2"></i> Talebi Gönder
                    </button>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        document.getElementById('tourSelect').addEventListener('change', function() {
            const selectedText = this.options[this.selectedIndex].text;
            document.getElementById('sumTourTitle').textContent = selectedText;
            document.getElementById('hiddenTourTitle').value = selectedText; 
        });

        function changeCount(val) {
            const input = document.getElementById('pCount');
            let current = parseInt(input.value);
            let next = current + val;

            if(next >= 1 && next <= 20) {
                input.value = next;
                document.getElementById('sumPersonCount').textContent = next + " Kişi";
            }
        }

        document.getElementById('resForm').onsubmit = function() {
            const btn = this.querySelector('button[type="submit"]');
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Gönderiliyor...';
            btn.style.opacity = '0.7';
        };
    </script>
}