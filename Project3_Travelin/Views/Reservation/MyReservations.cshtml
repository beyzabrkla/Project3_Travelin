@model List<ResultReservationDTO>
@{
    ViewData["Title"] = "Rezervasyonlarım";
    Layout = "~/Views/Shared/_CustomerLayout.cshtml";
}

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="page-title fs-3 fw-bold">Rezervasyonlarım</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/Customer/Dashboard">Panel</a></li>
                <li class="breadcrumb-item active" aria-current="page">Rezervasyonlarım</li>
            </ol>
        </nav>
    </div>
    <a href="/Reservation/NewReservation" class="btn btn-brand d-flex align-items-center gap-2" style="background-color: #6366f1; border:none; border-radius: 8px; padding: 10px 20px;">
        <i class="bi bi-plus-lg me-2"></i>Yeni Rezervasyon
    </a>
</div>

<div class="card border-0 shadow-sm" style="border-radius: 16px; overflow: hidden;">
    <div class="card-header bg-white py-3 border-bottom border-light">
        <div class="d-flex align-items-center justify-content-between">
            <h5 class="mb-0 fw-bold" style="color: #1a202c;">
                <i class="bi bi- luggage-fill me-2 text-primary"></i>Güncel Talepleriniz
            </h5>
            <span class="badge bg-light text-dark rounded-pill px-3">Toplam @Model.Count Kayıt</span>
        </div>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5">
            <div class="mb-3">
                <i class="bi bi-calendar-x text-muted" style="font-size: 4rem; opacity: 0.3;"></i>
            </div>
            <h5 class="text-muted">Henüz bir rezervasyonunuz bulunmuyor.</h5>
            <p class="small text-muted mb-4">Dünyayı keşfetmek için ilk adımınızı atın!</p>
            <a href="/Home/Index" class="btn btn-outline-primary rounded-pill px-4">Turları İncele</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 border-0 text-uppercase small fw-bold text-muted">Tur Bilgisi</th>
                        <th class="border-0 text-uppercase small fw-bold text-muted">Kişi</th>
                        <th class="border-0 text-uppercase small fw-bold text-muted">İletişim</th>
                        <th class="border-0 text-uppercase small fw-bold text-muted">Durum</th>
                        <th class="text-end pe-4 border-0 text-uppercase small fw-bold text-muted">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="icon-box me-3" style="width:45px; height:45px; background: rgba(99, 102, 241, 0.1); border-radius:10px; display:grid; place-items:center; color:#6366f1;">
                                        <i class="bi bi-map-fill"></i>
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark">@item.TourTitle</div>
                                        <div class="small text-muted">Tur ID: @item.TourId.ToString().Substring(0, 8)...</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border px-3 py-2" style="border-radius:8px;">
                                    <i class="bi bi-people-fill me-2"></i>@item.PersonCount Kişi
                                </span>
                            </td>
                            <td>
                                <div class="small fw-semibold">@item.CustomerPhone</div>
                                <div class="small text-muted">@item.CustomerEmail</div>
                            </td>
                            <td>
                                @if (item.Status?.ToLower() == "pending" || string.IsNullOrEmpty(item.Status))
                                {
                                    <span class="badge px-3 py-2" style="background: rgba(245, 158, 11, 0.1); color: #f59e0b; border-radius: 8px;">
                                        <i class="bi bi-clock-history me-1"></i>Onay Bekliyor
                                    </span>
                                }
                                else if (item.Status?.ToLower() == "approved")
                                {
                                    <span class="badge px-3 py-2" style="background: rgba(16, 185, 129, 0.1); color: #10b981; border-radius: 8px;">
                                        <i class="bi bi-check2-circle me-1"></i>Onaylandı
                                    </span>
                                }
                                else
                                {
                                    <span class="badge px-3 py-2" style="background: rgba(239, 68, 68, 0.1); color: #ef4444; border-radius: 8px;">
                                        <i class="bi bi-x-circle me-1"></i>İptal Edildi
                                    </span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group shadow-sm" style="border-radius: 8px; overflow: hidden;">
                                    <a href="/Reservation/Details/@item.ReservationId" class="btn btn-white btn-sm border-end" title="Detay">
                                        <i class="bi bi-info-circle text-primary"></i>
                                    </a>
                                    <button type="button" class="btn btn-white btn-sm" onclick="cancelReservation('@item.ReservationId')" title="İptal Et" @(item.Status == "Approved" ? "disabled" : "")>
                                        <i class="bi bi-trash text-danger"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
    <script>
        function cancelReservation(id) {
            // Buraya tatlı bir SweetAlert veya confirm kutusu ekleyebilirsin
            if(confirm("Bu rezervasyon talebini iptal etmek istediğinize emin misiniz?")) {
                window.location.href = "/Reservation/Cancel/" + id;
            }
        }
    </script>
}