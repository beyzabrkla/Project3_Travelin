@model EntityLayer.AppUser
@{
    ViewData["Title"] = "Kullanıcı Detayları";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var userRoles = ViewBag.UserRoles as IList<string>;
}

<div class="page-header mb-4">
    <div>
        <h1 class="page-title text-dark fw-bold">Kullanıcı Profili</h1>
        <nav aria-label="breadcrumb" class="mt-2">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="#" class="text-decoration-none">Admin</a></li>
                <li class="breadcrumb-item"><a href="/AdminUser/UserList" class="text-decoration-none">Kullanıcılar</a></li>
                <li class="breadcrumb-item active" aria-current="page">@Model.FullName</li>
            </ol>
        </nav>
    </div>
    <a href="/AdminUser/UserList" class="btn btn-outline-secondary d-flex align-items-center gap-2"
       style="border-radius:10px;font-size:.875rem;font-weight:500;padding:.55rem 1.1rem;">
        <i class="bi bi-arrow-left"></i> Listeye Dön
    </a>
</div>

<form asp-action="EditUser" method="post" id="editUserForm">
    @Html.AntiForgeryToken()
    <input type="hidden" name="userId" value="@Model.Id" />

    <div class="form-grid">
        @* ANA FORM ALANI (SOL) *@
        <div class="form-main">

            @* 1. Bölüm: Kimlik Bilgileri *@
            <div class="form-section mb-4">
                <div class="section-header">
                    <div class="section-icon blue"><i class="bi bi-person-vcard"></i></div>
                    <div>
                        <div class="section-title">Hesap Bilgileri</div>
                        <div class="section-subtitle">Temel kullanıcı ve erişim detayları</div>
                    </div>
                </div>
                <div class="section-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="field-group">
                                <label class="field-label">Ad Soyad <span class="required">*</span></label>
                                <input type="text" name="fullName" class="form-control" value="@Model.FullName" required />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="field-group">
                                <label class="field-label">Kullanıcı Adı</label>
                                <input type="text" class="form-control" value="@Model.UserName" readonly style="background-color: #f8f9fa;" />
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class="field-group">
                                <label class="field-label">E-posta Adresi <span class="required">*</span></label>
                                <input type="email" name="email" class="form-control" value="@Model.Email" required />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* 2. Bölüm: Mevcut Roller (Sadece Bilgi Amaçlı) *@
            <div class="form-section">
                <div class="section-header">
                    <div class="section-icon purple"><i class="bi bi-shield-lock"></i></div>
                    <div>
                        <div class="section-title">Atanmış Roller</div>
                        <div class="section-subtitle">Kullanıcının sistemdeki yetki seviyeleri</div>
                    </div>
                </div>
                <div class="section-body">
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var role in userRoles)
                        {
                            <div class="p-2 border rounded-3 d-flex align-items-center gap-2" style="background: #f8fafc; min-width: 140px;">
                                <i class="bi bi-check-circle-fill text-primary"></i>
                                <span class="fw-bold small">@role.ToUpper()</span>
                            </div>
                        }
                    </div>
                </div>
            </div>

        </div>

        @* YAN PANEL (SAĞ) *@
        <div class="sidebar-panel">

            @* Durum Kartı *@
            <div class="form-section mb-4">
                <div class="section-header">
                    <div class="section-icon @(Model.IsActive ? "green" : "red")">
                        <i class="bi bi-power"></i>
                    </div>
                    <div>
                        <div class="section-title">Hesap Durumu</div>
                        <div class="section-subtitle">Giriş yetkisi kontrolü</div>
                    </div>
                </div>
                <div class="section-body text-center p-3">
                    <div class="mb-3">
                        <div class="bg-primary text-white d-inline-flex align-items-center justify-content-center shadow-sm mb-2"
                             style="width: 80px; height: 80px; border-radius: 25px; font-size: 2.2rem; font-weight:700;">
                            @(Model.FullName?.Substring(0, 1).ToUpper() ?? "U")
                        </div>
                    </div>

                    @if (Model.IsActive)
                    {
                        <div class="badge bg-soft-success text-success p-2 w-100 mb-2" style="background:#ecfdf5;">
                            <i class="bi bi-check-circle me-1"></i> AKTİF KULLANICI
                        </div>
                    }
                    else
                    {
                        <div class="badge bg-soft-danger text-danger p-2 w-100 mb-2" style="background:#fff1f2;">
                            <i class="bi bi-x-circle me-1"></i> PASİF KULLANICI
                        </div>
                    }
                    <p class="text-muted small mt-2">Durum değişikliği için kullanıcı listesini kullanın.</p>
                </div>
            </div>

            @* İşlem Kartı *@
            <div class="form-section sticky-top" style="top: 20px; z-index: 10;">
                <div class="section-body">
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-brand py-2 fw-bold" id="submitBtn" style="background-color: #4f46e5; color:white; border:none; border-radius:8px;">
                            <i class="bi bi-floppy-fill me-2"></i> Bilgileri Güncelle
                        </button>
                        <a href="/AdminUser/UserList" class="btn btn-light py-2 text-muted border" style="border-radius:8px;">
                            İptal Et
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</form>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#editUserForm').on('submit', function () {
                const btn = $('#submitBtn');
                btn.prop('disabled', true);
                btn.html('<span class="spinner-border spinner-border-sm me-2"></span>İşleniyor...');
                return true;
            });
        });
    </script>
}