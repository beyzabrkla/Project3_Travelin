@model List<ResultGuideDTO>
@{
    ViewData["Title"] = "Rehber Listesi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="page-title fw-bold">Rehber Yönetimi</h1>
        <nav aria-label="breadcrumb" class="mt-2">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/Admin/Dashboard">Admin</a></li>
                <li class="breadcrumb-item active" aria-current="page">Rehberler</li>
            </ol>
        </nav>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card shadow-sm border-0" style="border-radius: 20px; overflow: hidden;">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light text-muted text-uppercase" style="font-size: .75rem; letter-spacing: 0.05em;">
                            <tr>
                                <th class="ps-4 py-3">REHBER BİLGİSİ</th>
                                <th class="py-3">UZMANLIK ALANI</th>
                                <th class="py-3 text-center">DURUM</th>
                                <th class="py-3 text-center" style="width: 200px;">İŞLEMLER</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 py-3">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="position-relative">
                                                <img src="@item.ImageUrl" alt="@item.Name"
                                                     style="width: 50px; height: 50px; object-fit: cover; border-radius: 14px; border: 2px solid #f1f5f9;">
                                                @if (item.Status)
                                                {
                                                    <span class="position-absolute bottom-0 end-0 bg-success border border-white border-2 rounded-circle" style="width:12px; height:12px;"></span>
                                                }
                                            </div>
                                            <div>
                                                <div class="fw-bold text-dark" style="font-size: .95rem;">@item.Name</div>
                                                <div class="text-muted small">@item.Title</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="py-3">
                                        <div class="d-flex flex-column">
                                            <span class="text-secondary fw-medium">@item.Specialization</span>
                                            <small class="text-muted"><i class="bi bi-translate me-1"></i> @item.Languages</small>
                                        </div>
                                    </td>
                                    <td class="py-3 text-center">
                                        @if (item.Status)
                                        {
                                            <span class="badge bg-soft-success text-success px-3 py-2" style="background:#dcfce7; border-radius: 10px;">
                                                <i class="bi bi-check-circle-fill me-1"></i> Aktif
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-soft-danger text-danger px-3 py-2" style="background:#fee2e2; border-radius: 10px;">
                                                <i class="bi bi-x-circle-fill me-1"></i> Pasif
                                            </span>
                                        }
                                    </td>
                                    <td class="py-3 text-center pe-4">
                                        <div class="d-flex justify-content-center gap-2">
                                            <form asp-action="ToggleStatus" asp-route-id="@item.GuideId" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-secondary shadow-none" title="Durumu Değiştir" style="border-radius: 8px;">
                                                    <i class="bi bi-arrow-repeat"></i>
                                                </button>
                                            </form>

                                            <a asp-action="UpdateGuide" asp-route-id="@item.GuideId"
                                               class="btn btn-sm btn-outline-primary shadow-none" style="border-radius: 8px;">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>

                                            <button type="button" class="btn btn-sm btn-outline-danger shadow-none"
                                                    style="border-radius: 8px;"
                                                    onclick="confirmDelete('@item.GuideId', '@item.Name')">
                                                <i class="bi bi-trash3"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 bg-white shadow-sm mt-3" style="border-radius: 20px;">
        <i class="bi bi-person-exclamation text-muted" style="font-size: 3.5rem;"></i>
        <p class="mt-2 text-secondary fw-medium">Sistemde henüz kayıtlı bir rehber bulunamadı.</p>
        <a asp-action="CreateGuide" class="btn btn-primary btn-sm mt-2" style="border-radius: 8px;">İlk Rehberi Ekle</a>
    </div>
}

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    function confirmDelete(id, name) {
        Swal.fire({
            title: 'Emin misiniz?',
            text: `"${name}" isimli rehber kalıcı olarak silinecektir!`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#64748b',
            confirmButtonText: 'Evet, Sil!',
            cancelButtonText: 'Vazgeç',
            customClass: {
                popup: 'rounded-4',
                confirmButton: 'rounded-3 px-4',
                cancelButton: 'rounded-3 px-4'
            }
        }).then((result) => {
            if (result.isConfirmed) {
                const form = document.createElement('form');
                form.method = 'post';
                form.action = '/AdminUser/DeleteGuide';

                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                if (token) {
                    const tokenInput = document.createElement('input');
                    tokenInput.type = 'hidden';
                    tokenInput.name = '__RequestVerificationToken';
                    tokenInput.value = token;
                    form.appendChild(tokenInput);
                }

                const idInput = document.createElement('input');
                idInput.type = 'hidden';
                idInput.name = 'id';
                idInput.value = id;

                form.appendChild(idInput);
                document.body.appendChild(form);
                form.submit();
            }
        })
    }
</script>