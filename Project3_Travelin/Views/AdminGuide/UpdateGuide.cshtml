@model UpdateGuideDTO
@{
    ViewData["Title"] = "Rehber Düzenle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@if (ViewBag.Errors != null)
{
    <div class="alert alert-danger">
        <ul>
            @foreach (var error in ViewBag.Errors)
            {
                <li>@error</li>
            }
        </ul>
    </div>
}

<!-- PAGE HEADER -->
<div class="page-header">
    <div>
        <h1 class="page-title">Rehber Düzenle</h1>
        <nav aria-label="breadcrumb" class="mt-2">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="#">Admin</a></li>
                <li class="breadcrumb-item"><a asp-action="GuideList">Rehberler</a></li>
                <li class="breadcrumb-item active" aria-current="page">Rehber Düzenle</li>
            </ol>
        </nav>
    </div>
    <a asp-action="GuideList" class="btn btn-outline-secondary d-flex align-items-center gap-2"
       style="border-radius:10px;font-size:.875rem;font-weight:500;padding:.55rem 1.1rem;">
        <i class="bi bi-arrow-left"></i> Listeye Dön
    </a>
</div>

<form asp-action="UpdateGuide" method="post" id="updateGuideForm">
    <input type="hidden" asp-for="GuideId" />
    @Html.AntiForgeryToken()

    <div class="form-grid">
        <div class="form-main">

            <!-- TEMEL BİLGİLER -->
            <div class="form-section">
                <div class="section-header">
                    <div class="section-icon blue"><i class="bi bi-person"></i></div>
                    <div>
                        <div class="section-title">Temel Bilgiler</div>
                        <div class="section-subtitle">Rehberin adı ve unvanı</div>
                    </div>
                </div>
                <div class="section-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="field-group">
                                <label asp-for="Name" class="field-label">
                                    <i class="bi bi-person" style="color:#a0aec0;font-size:.85rem;"></i>
                                    Ad Soyad <span class="required">*</span>
                                </label>
                                <input asp-for="Name" class="form-control" placeholder="Örn: Ahmet Yılmaz" />
                                <span asp-validation-for="Name" class="text-danger-field">
                                    <i class="bi bi-exclamation-circle"></i><span></span>
                                </span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="field-group">
                                <label asp-for="Title" class="field-label">
                                    <i class="bi bi-briefcase" style="color:#a0aec0;font-size:.85rem;"></i>
                                    Unvan <span class="required">*</span>
                                </label>
                                <input asp-for="Title" class="form-control" placeholder="Örn: Profesyonel Dağcı" />
                                <span asp-validation-for="Title" class="text-danger-field">
                                    <i class="bi bi-exclamation-circle"></i><span></span>
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="field-group mt-3">
                        <label asp-for="Description" class="field-label">
                            <i class="bi bi-text-left" style="color:#a0aec0;font-size:.85rem;"></i>
                            Açıklama <span class="required">*</span>
                        </label>
                        <textarea asp-for="Description" class="form-control" rows="5"
                                  placeholder="Rehber hakkında detaylı açıklama yazın..." maxlength="1000" id="descInput"></textarea>
                        <div class="char-counter" id="descCounter">0 / 1000</div>
                        <span asp-validation-for="Description" class="text-danger-field">
                            <i class="bi bi-exclamation-circle"></i><span></span>
                        </span>
                    </div>
                </div>
            </div>

            <!-- GÖRSEL -->
            <div class="form-section">
                <div class="section-header">
                    <div class="section-icon purple"><i class="bi bi-image"></i></div>
                    <div>
                        <div class="section-title">Profil Görseli</div>
                        <div class="section-subtitle">Rehberin profil fotoğrafı</div>
                    </div>
                </div>
                <div class="section-body">
                    <div class="field-group">
                        <label asp-for="ImageUrl" class="field-label">
                            <i class="bi bi-link-45deg" style="color:#a0aec0;font-size:.85rem;"></i>
                            Görsel URL
                        </label>
                        <div class="input-with-icon">
                            <i class="bi bi-link-45deg input-icon"></i>
                            <input asp-for="ImageUrl" type="url" class="form-control"
                                   placeholder="https://ornek.com/foto.jpg" id="imageUrlInput" />
                        </div>
                        <div class="field-hint"><i class="bi bi-info-circle me-1"></i>JPEG, PNG, WebP desteklenir.</div>
                        <img src="" alt="Önizleme" id="urlPreviewImg"
                             style="display:none;margin-top:.75rem;width:120px;height:120px;object-fit:cover;border-radius:50%;border:3px solid #e2e8f0;" />
                        <span asp-validation-for="ImageUrl" class="text-danger-field">
                            <i class="bi bi-exclamation-circle"></i><span></span>
                        </span>
                    </div>
                </div>
            </div>

        </div><!-- /form-main -->
        <!-- SIDEBAR -->
        <div class="sidebar-panel">
            <div class="form-section">
                <div class="section-header">
                    <div class="section-icon green"><i class="bi bi-send-check"></i></div>
                    <div>
                        <div class="section-title">Durum</div>
                        <div class="section-subtitle">Rehber aktif olsun mu?</div>
                    </div>
                </div>
                <div class="section-body">
                    <label class="status-option" id="statusActive">
                        <input type="radio" name="StatusRadio" value="true" onchange="setStatus(this)" />
                        <span class="status-dot dot-active"></span>
                        <div class="status-text">
                            <div class="stitle">Aktif</div>
                            <div class="ssub">Listede görünsün</div>
                        </div>
                        <i class="bi bi-check-circle-fill ms-auto" style="color:#16a34a;font-size:.95rem;"></i>
                    </label>
                    <label class="status-option" id="statusPassive">
                        <input type="radio" name="StatusRadio" value="false" onchange="setStatus(this)" />
                        <span class="status-dot dot-passive"></span>
                        <div class="status-text">
                            <div class="stitle">Pasif</div>
                            <div class="ssub">Gizle</div>
                        </div>
                    </label>
                    <input type="hidden" asp-for="Status" id="statusHidden" />
                </div>
            </div>

            <div class="form-section">
                <div class="section-body">
                    <div class="form-actions">
                        <button type="submit" class="btn btn-brand" id="submitBtn">
                            <i class="bi bi-floppy-fill"></i> Değişiklikleri Kaydet
                        </button>
                        <a asp-action="GuideList" class="btn-cancel">
                            <i class="bi bi-x me-1"></i>İptal et, geri dön
                        </a>
                    </div>
                </div>
            </div>
        </div><!-- /sidebar -->

    </div><!-- /form-grid -->
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Char counter
        const descEl = document.getElementById('descInput');
        const descCounter = document.getElementById('descCounter');
        function updateCounter() {
            const len = descEl.value.length;
            descCounter.textContent = len + ' / 1000';
            descCounter.className = 'char-counter' + (len > 900 ? (len >= 1000 ? ' danger' : ' warn') : '');
        }
        descEl.addEventListener('input', updateCounter);
        updateCounter();

        // Görsel önizleme — mevcut URL varsa göster
        const imageUrlInput = document.getElementById('imageUrlInput');
        const urlPreviewImg = document.getElementById('urlPreviewImg');

        (function initPreview() {
            const url = imageUrlInput.value.trim();
            if (url) {
                urlPreviewImg.src = url;
                urlPreviewImg.style.display = 'block';
            }
        })();

        let debounce;
        imageUrlInput.addEventListener('input', function () {
            clearTimeout(debounce);
            debounce = setTimeout(function () {
                const url = imageUrlInput.value.trim();
                if (url) {
                    urlPreviewImg.src = url;
                    urlPreviewImg.style.display = 'block';
                    urlPreviewImg.onerror = function () { urlPreviewImg.style.display = 'none'; };
                } else {
                    urlPreviewImg.style.display = 'none';
                }
            }, 600);
        });

        // Durum — model'den gelen değere göre radyo seç
        window.addEventListener('DOMContentLoaded', function () {
            const currentStatus = "@Model.Status".toLowerCase() === "true";
            const targetRadio = document.querySelector('input[name="StatusRadio"][value="' + currentStatus + '"]');
            if (targetRadio) {
                targetRadio.checked = true;
                setStatus(targetRadio);
            }
        });

        function setStatus(radio) {
            document.querySelectorAll('.status-option').forEach(el => {
                el.classList.remove('selected-active', 'selected-passive');
            });
            const parent = radio.closest('.status-option');
            document.getElementById('statusHidden').value = radio.value;
            if (radio.value === 'true') parent.classList.add('selected-active');
            else parent.classList.add('selected-passive');
        }

        // Submit feedback
        $(document).ready(function () {
            $('#updateGuideForm').on('submit', function () {
                if (!$(this).valid()) return false;
                const btn = $('#submitBtn');
                btn.prop('disabled', true);
                btn.html('<span class="spinner-border spinner-border-sm me-2"></span>Kaydediliyor...');
                return true;
            });
        });
    </script>
}
